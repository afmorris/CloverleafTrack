@model MeetFormViewModel
@{
    ViewData["Title"] = "Edit Meet";
}

@await Html.PartialAsync("Create", Model)

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        const meetTypeSelect = document.getElementById('meetTypeSelect');
        const scoringTemplateGroup = document.getElementById('scoringTemplateGroup');
        const addBtn = document.getElementById('addParticipantBtn');

        function updateMeetTypeUI() {
            const val = meetTypeSelect.value;
            scoringTemplateGroup.style.display = val == '3' ? 'block' : 'none';
        }

        meetTypeSelect.addEventListener('change', updateMeetTypeUI);
        updateMeetTypeUI();

        const schoolOptions = `<option value="0">Select school...</option>` +
            @Html.Raw(string.Concat(Model.Schools.Select((s, idx) =>
                $"'<option value=\"{s.Id}\">{System.Net.WebUtility.HtmlEncode(s.DisplayText)}</option>'"
                + (idx < Model.Schools.Count - 1 ? " +" : ""))));

        let participantIndex = document.querySelectorAll('.participant-row').length;
        addBtn.addEventListener('click', function () {
            const row = document.createElement('div');
            row.className = 'participant-row';
            row.style.cssText = 'display:flex;gap:8px;margin-bottom:8px;';
            row.innerHTML = `<select name="ParticipantSchoolIds[${participantIndex}]" class="form-control" style="flex:1">${schoolOptions}</select>
                             <button type="button" onclick="this.closest('.participant-row').remove()"
                                     style="padding:8px 12px;background:#dc3545;color:white;border:none;border-radius:4px;cursor:pointer;">✕</button>`;
            document.getElementById('participantInputs').appendChild(row);
            participantIndex++;
        });
    </script>
}
