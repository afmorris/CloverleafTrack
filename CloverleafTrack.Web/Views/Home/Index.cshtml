@model HomePageViewModel

@{
    ViewData["Title"] = "Cloverleaf Track & Field";
}

<div class="max-w-4xl mx-auto px-4 sm:px-6">

    @* 1. Latest meet header + impact strip *@
    @await Html.PartialAsync("_HomePageLatestMeetImpactCard", Model)

    @* 2. Highlights digest *@
    @await Html.PartialAsync("_HomePageHighlightsDigest", Model)

    @* 3. On This Day (slim line) *@
    @await Html.PartialAsync("_HomePageOnThisDayCard", Model)

    @* 4. Season strip *@
    @await Html.PartialAsync("_HomePageSeasonAtAGlanceCard", Model)

    @* 5. Upcoming meets *@
    @await Html.PartialAsync("_HomePageUpcomingMeets", Model)

</div>
