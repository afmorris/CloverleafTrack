@using Slugify
@model MeetDetailsViewModel

@{
    ViewBag.Title = Model.Name;
    var allEventPerformances = Model.BoysEvents
        .Concat(Model.GirlsEvents)
        .Concat(Model.MixedEvents)
        .SelectMany(eventGroup => eventGroup.Performances.Select(performance => new
        {
            eventGroup.EventName,
            Performance = performance
        }))
        .ToList();
    var summarySchoolRecords = allEventPerformances
        .Where(item => item.Performance.IsSchoolRecord)
        .Take(5)
        .ToList();
    var summaryTopTen = allEventPerformances
        .Where(item => item.Performance.AllTimeRank is <= 10)
        .Take(5)
        .ToList();
    var summaryPRs = allEventPerformances
        .Where(item => item.Performance.IsPersonalBest)
        .Take(5)
        .ToList();
    var summaryRelays = allEventPerformances
        .Where(item => IsRelay(item.Performance.AthleteName))
        .Take(5)
        .ToList();
}

@functions {
    bool IsRelay(string athleteName)
    {
        return athleteName?.Contains("|~|") ?? false;
    }

    string[] GetRelayAthletes(string athleteName)
    {
        return athleteName?.Split("|~|") ?? Array.Empty<string>();
    }
    
    string GetCategoryName(CloverleafTrack.Models.Enums.EventCategory category)
    {
        return category switch
        {
            CloverleafTrack.Models.Enums.EventCategory.Sprints => "Sprints",
            CloverleafTrack.Models.Enums.EventCategory.Distance => "Distance",
            CloverleafTrack.Models.Enums.EventCategory.Throws => "Throws",
            CloverleafTrack.Models.Enums.EventCategory.Jumps => "Jumps",
            CloverleafTrack.Models.Enums.EventCategory.Relays => "Relays",
            CloverleafTrack.Models.Enums.EventCategory.Hurdles => "Hurdles",
            _ => "Other"
        };
    }
}


<!-- Main Content -->
<div class="max-w-7xl mx-auto px-6">

    <!-- Header -->
    <div class="mb-8">
        <div class="mb-4">
            <a asp-controller="Seasons" asp-action="Details" asp-route-name="@Model.SeasonName" class="text-gray-600 dark:text-gray-400 text-sm mb-2 inline-block">
                ← Back to @Model.SeasonName Season
            </a>
        </div>
        <h1 class="text-4xl font-bold text-gray-900 dark:text-white">@Model.Name</h1>
        
        <div class="flex flex-wrap gap-6 text-gray-600 dark:text-gray-300">
            <div class="flex items-center gap-2">
                <span class="text-xl">📅</span>
                <span>@Model.Date.ToString("MMMM d, yyyy")</span>
            </div>
            <div class="flex items-center gap-2">
                <span class="text-xl">📍</span>
                <span>@Model.LocationName@(string.IsNullOrEmpty(Model.LocationCity) ? "" : $", {Model.LocationCity}")@(string.IsNullOrEmpty(Model.LocationState) ? "" : $", {Model.LocationState}")</span>
            </div>
            <div class="flex items-center gap-2">
                @if (Model.Environment == CloverleafTrack.Models.Enums.Environment.Indoor)
                {
                    <span class="px-3 py-1 bg-blue-50 dark:bg-blue-900/20 text-blue-700 dark:text-blue-300 rounded-lg border border-blue-200 dark:border-blue-700/30 text-sm font-medium">
                        🏢 Indoor
                    </span>
                }
                else
                {
                    <span class="px-3 py-1 bg-amber-50 dark:bg-amber-900/20 text-amber-700 dark:text-amber-300 rounded-lg border border-amber-200 dark:border-amber-700/30 text-sm font-medium">
                        ☀️ Outdoor
                    </span>
                }
            </div>
            @if (Model.HandTimed)
            {
                <div class="flex items-center gap-2">
                    <span class="px-3 py-1 bg-gray-700 text-gray-300 rounded-lg border border-gray-600 text-sm font-medium">
                        ⏱️ Hand-Timed
                    </span>
                </div>
            }
        </div>
    </div>

    <!-- Meet Impact Summary -->
    <div class="mb-12">
        <div class="flex flex-wrap items-center justify-between gap-3 mb-6">
            <h2 class="text-2xl font-bold text-gray-900 dark:text-white">Meet Impact Summary</h2>
            <div class="flex flex-wrap gap-2">
                @if (Model.HasMixedEvents)
                {
                    <span class="px-3 py-1 text-xs font-semibold rounded-full bg-purple-50 dark:bg-purple-900/20 text-purple-700 dark:text-purple-300 border border-purple-200 dark:border-purple-700/30">Mixed relays</span>
                }
                @if (Model.HandTimed)
                {
                    <span class="px-3 py-1 text-xs font-semibold rounded-full bg-gray-100 dark:bg-gray-700 text-gray-700 dark:text-gray-300 border border-gray-200 dark:border-gray-600">Hand-timed marks</span>
                }
            </div>
        </div>

        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-6">
            <div class="bg-white dark:bg-gray-800 rounded-xl p-6 border border-purple-200 dark:border-purple-700/30">
                <div class="text-sm text-purple-700 dark:text-purple-300 mb-2 font-semibold uppercase tracking-wide">Total Performances</div>
                <div class="text-4xl font-bold text-purple-900 dark:text-purple-100">@Model.TotalPerformances</div>
            </div>
            <div class="bg-white dark:bg-gray-800 rounded-xl p-6 border border-blue-200 dark:border-blue-700/30">
                <div class="text-sm text-blue-700 dark:text-blue-300 mb-2 font-semibold uppercase tracking-wide">Athletes</div>
                <div class="text-4xl font-bold text-blue-900 dark:text-blue-100">@Model.UniqueAthletes</div>
            </div>
            <div class="bg-white dark:bg-gray-800 rounded-xl p-6 border border-green-200 dark:border-green-700/30">
                <div class="text-sm text-green-700 dark:text-green-300 mb-2 font-semibold uppercase tracking-wide">PRs</div>
                <div class="text-4xl font-bold text-green-900 dark:text-green-100">@Model.TotalPRs</div>
            </div>
            <div class="bg-white dark:bg-gray-800 rounded-xl p-6 border border-yellow-200 dark:border-yellow-700/30">
                <div class="text-sm text-yellow-700 dark:text-yellow-300 mb-2 font-semibold uppercase tracking-wide">School Records</div>
                <div class="text-4xl font-bold text-yellow-900 dark:text-yellow-100">@Model.TotalSchoolRecords</div>
            </div>
            <div class="bg-white dark:bg-gray-800 rounded-xl p-6 border border-purple-200 dark:border-purple-700/30">
                <div class="text-sm text-purple-700 dark:text-purple-300 mb-2 font-semibold uppercase tracking-wide">Top-10 Marks</div>
                <div class="text-4xl font-bold text-purple-900 dark:text-purple-100">@Model.TopTenAllTimeCount</div>
            </div>
            <div class="bg-white dark:bg-gray-800 rounded-xl p-6 border border-blue-200 dark:border-blue-700/30">
                <div class="text-sm text-blue-700 dark:text-blue-300 mb-2 font-semibold uppercase tracking-wide">Season Bests</div>
                <div class="text-4xl font-bold text-blue-900 dark:text-blue-100">@Model.SeasonBestCount</div>
            </div>
            @if (Model.HasScoring)
            {
                <div class="bg-white dark:bg-gray-800 rounded-xl p-6 border border-orange-200 dark:border-orange-700/30">
                    <div class="text-sm text-orange-800 dark:text-orange-200 mb-2 font-semibold uppercase tracking-wide">Scoring Places</div>
                    <div class="text-4xl font-bold text-orange-800 dark:text-orange-200">@Model.PlacingCount</div>
                </div>
            }
        </div>

        @if (summarySchoolRecords.Any() || summaryTopTen.Any() || summaryPRs.Any() || summaryRelays.Any())
        {
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
                @if (summarySchoolRecords.Any())
                {
                    <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 overflow-hidden">
                        <div class="px-5 py-3 border-b border-gray-200 dark:border-gray-700 text-sm font-semibold text-yellow-700 dark:text-yellow-300 uppercase tracking-wide">School Records</div>
                        <div class="divide-y divide-gray-200 dark:divide-gray-700">
                            @foreach (var item in summarySchoolRecords)
                            {
                                <div class="px-5 py-3">
                                    <div class="font-semibold text-gray-900 dark:text-white">@item.EventName · @item.Performance.Performance</div>
                                    <div class="text-sm text-gray-600 dark:text-gray-400">@((IsRelay(item.Performance.AthleteName) ? string.Join(" / ", GetRelayAthletes(item.Performance.AthleteName)) : item.Performance.AthleteName))</div>
                                </div>
                            }
                        </div>
                    </div>
                }

                @if (summaryTopTen.Any())
                {
                    <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 overflow-hidden">
                        <div class="px-5 py-3 border-b border-gray-200 dark:border-gray-700 text-sm font-semibold text-purple-700 dark:text-purple-300 uppercase tracking-wide">Top-10 All-Time Marks</div>
                        <div class="divide-y divide-gray-200 dark:divide-gray-700">
                            @foreach (var item in summaryTopTen)
                            {
                                <div class="px-5 py-3">
                                    <div class="font-semibold text-gray-900 dark:text-white">@item.EventName · @item.Performance.Performance</div>
                                    <div class="text-sm text-gray-600 dark:text-gray-400">#@item.Performance.AllTimeRank all-time · @((IsRelay(item.Performance.AthleteName) ? string.Join(" / ", GetRelayAthletes(item.Performance.AthleteName)) : item.Performance.AthleteName))</div>
                                </div>
                            }
                        </div>
                    </div>
                }

                @if (summaryPRs.Any())
                {
                    <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 overflow-hidden">
                        <div class="px-5 py-3 border-b border-gray-200 dark:border-gray-700 text-sm font-semibold text-green-700 dark:text-green-300 uppercase tracking-wide">PRs</div>
                        <div class="divide-y divide-gray-200 dark:divide-gray-700">
                            @foreach (var item in summaryPRs)
                            {
                                <div class="px-5 py-3">
                                    <div class="font-semibold text-gray-900 dark:text-white">@item.EventName · @item.Performance.Performance</div>
                                    <div class="text-sm text-gray-600 dark:text-gray-400">@((IsRelay(item.Performance.AthleteName) ? string.Join(" / ", GetRelayAthletes(item.Performance.AthleteName)) : item.Performance.AthleteName))</div>
                                </div>
                            }
                        </div>
                    </div>
                }

                @if (summaryRelays.Any())
                {
                    <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 overflow-hidden">
                        <div class="px-5 py-3 border-b border-gray-200 dark:border-gray-700 text-sm font-semibold text-purple-700 dark:text-purple-300 uppercase tracking-wide">Relay Results</div>
                        <div class="divide-y divide-gray-200 dark:divide-gray-700">
                            @foreach (var item in summaryRelays)
                            {
                                <div class="px-5 py-3">
                                    <div class="font-semibold text-gray-900 dark:text-white">@item.EventName · @item.Performance.Performance</div>
                                    <div class="text-sm text-gray-600 dark:text-gray-400">@string.Join(" / ", GetRelayAthletes(item.Performance.AthleteName))</div>
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>
        }
    </div>

    <!-- Results by Gender -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
        
        <!-- Boys Results -->
        <div>
            <h2 class="text-2xl font-bold mb-6 text-blue-600 dark:text-blue-400 flex items-center gap-2">
                <span>♂</span>
                <span>Boys</span>
            </h2>
            
        @if (Model.BoysEvents.Any())
        {
            var boysGrouped = Model.BoysEvents.GroupBy(e => e.EventCategory);
            
            @foreach (var categoryGroup in boysGrouped)
            {
                <div class="mb-8">
                    <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-4">@GetCategoryName(categoryGroup.Key)</h3>
                    
                    <div class="space-y-4">
                        @foreach (var eventGroup in categoryGroup)
                        {
                            <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl overflow-hidden">
                                <div class="bg-blue-50 dark:bg-blue-900/20 border-b border-blue-200 dark:border-blue-700/30 px-5 py-3">
                                    <h4 class="text-lg font-semibold text-blue-900 dark:text-blue-300">@eventGroup.EventName</h4>
                                </div>
                                
                                <div class="overflow-x-auto">
                                    <table class="min-w-full text-sm">
                                        <thead class="border-b border-gray-200 dark:border-gray-700">
                                            <tr class="text-gray-600 dark:text-gray-400 text-xs">
                                                <th class="px-5 py-3 text-left font-medium">Athlete</th>
                                                <th class="px-5 py-3 text-left font-medium">Mark</th>
                                                <th class="px-5 py-3 text-center font-medium">Notes</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var perf in eventGroup.Performances)
                                            {
                                                <tr class="border-t border-gray-200/50 dark:border-gray-700/50 hover:bg-gray-200/30 dark:hover:bg-gray-700/30 transition-colors">
                                                    <td class="px-5 py-3">
                                                        @if (IsRelay(perf.AthleteName))
                                                        {
                                                            <div class="space-y-1">
                                                                @foreach (var athlete in GetRelayAthletes(perf.AthleteName))
                                                                {
                                                                    var split = athlete.Split(' ');
                                                                    if (split.Length >= 2)
                                                                    {
                                                                        var firstName = split[0];
                                                                        var lastName = split[1];
                                                                        var helper = new SlugHelper();
                                                                        var slug = helper.GenerateSlug($"{firstName}-{lastName}");
                                                                        
                                                                        <div class="text-gray-900 dark:text-white">
                                                                            <span class="mr-2">•</span>
                                                                            <a asp-controller="Roster" asp-action="Details" asp-route-slug="@slug" class="underline">
                                                                                @athlete
                                                                            </a>
                                                                        </div>
                                                                    }
                                                                }
                                                            </div>
                                                        }
                                                        else
                                                        {
                                                            var split = perf.AthleteName.Split(' ');
                                                            if (split.Length >= 2)
                                                            {
                                                                var firstName = split[0];
                                                                var lastName = split[1];
                                                                var helper = new SlugHelper();
                                                                var slug = helper.GenerateSlug($"{firstName}-{lastName}");

                                                                <a asp-controller="Roster" asp-action="Details" asp-route-slug="@slug" class="text-gray-900 dark:text-white underline">
                                                                    @perf.AthleteName
                                                                </a>
                                                            }
                                                            else
                                                            {
                                                                <span class="text-gray-900 dark:text-white">@perf.AthleteName</span>
                                                            }
                                                        }
                                                    </td>
                                                    <td class="px-5 py-3">
                                                        <span class="font-mono font-semibold text-lg text-gray-900 dark:text-white">@perf.Performance</span>
                                                    </td>
                                                    <td class="px-5 py-3">
                                                        <div class="flex justify-center gap-2 flex-wrap">
                                                            @if (perf.IsSchoolRecord)
                                                            {
                                                                <span class="inline-block px-2 py-1 text-xs font-semibold rounded bg-yellow-50 dark:bg-yellow-900/20 text-yellow-800 dark:text-yellow-200 border border-yellow-200 dark:border-yellow-700/30" title="School Record">
                                                                    SR
                                                                </span>
                                                            }
                                                            @if (perf.IsPersonalBest)
                                                            {
                                                                <span class="inline-block px-2 py-1 text-xs font-semibold rounded bg-green-50 dark:bg-green-900/20 text-green-800 dark:text-green-200 border border-green-200 dark:border-green-700/30" title="Personal Best">
                                                                    PR
                                                                </span>
                                                            }
                                                            @if (perf.IsSeasonBest)
                                                            {
                                                                <span class="inline-block px-2 py-1 text-xs font-semibold rounded bg-blue-50 dark:bg-blue-900/20 text-blue-800 dark:text-blue-200 border border-blue-200 dark:border-blue-700/30" title="Season Best">
                                                                    SB
                                                                </span>
                                                            }
                                                            @if (perf.AllTimeRank.HasValue && perf.AllTimeRank <= 10)
                                                            {
                                                                <span class="inline-block px-2 py-1 text-xs font-semibold rounded bg-purple-50 dark:bg-purple-900/20 text-purple-800 dark:text-purple-200 border border-purple-200 dark:border-purple-700/30" title="All-Time Top 10">
                                                                    #@perf.AllTimeRank AT
                                                                </span>
                                                            }
                                                            @foreach (var placing in perf.Placings)
                                                            {
                                                                <span class="inline-flex items-center gap-1 px-2 py-1 text-xs font-semibold rounded bg-orange-50 dark:bg-orange-900/20 text-orange-800 dark:text-orange-200 border border-orange-200 dark:border-orange-700/30"
                                                                      title="@(placing.OpponentSchoolName != null ? $"Place vs. {placing.OpponentSchoolName}" : "Place")">
                                                                    @placing.MedalEmoji@(placing.OpponentSchoolName != null ? $" vs. {placing.OpponentSchoolName}" : "")
                                                                </span>
                                                            }
                                                        </div>
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }
        }
        else
        {
            <div class="p-8 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl text-center">
                <p class="text-gray-600 dark:text-gray-400">No boys results for this meet.</p>
            </div>
        }
        </div>

        <!-- Girls Results -->
        <div>
            <h2 class="text-2xl font-bold mb-6 text-pink-600 dark:text-pink-400 flex items-center gap-2">
                <span>♀</span>
                <span>Girls</span>
            </h2>
            
        @if (Model.GirlsEvents.Any())
        {
            var girlsGrouped = Model.GirlsEvents.GroupBy(e => e.EventCategory);
            
            @foreach (var categoryGroup in girlsGrouped)
            {
                <div class="mb-8">
                    <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-4">@GetCategoryName(categoryGroup.Key)</h3>
                    
                    <div class="space-y-4">
                        @foreach (var eventGroup in categoryGroup)
                        {
                            <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl overflow-hidden">
                                <div class="bg-pink-50 dark:bg-pink-900/20 border-b border-pink-200 dark:border-pink-700/30 px-5 py-3">
                                    <h4 class="text-lg font-semibold text-pink-900 dark:text-pink-300">@eventGroup.EventName</h4>
                                </div>
                                
                                <div class="overflow-x-auto">
                                    <table class="min-w-full text-sm">
                                        <thead class="border-b border-gray-200 dark:border-gray-700">
                                            <tr class="text-gray-600 dark:text-gray-400 text-xs">
                                                <th class="px-5 py-3 text-left font-medium">Athlete</th>
                                                <th class="px-5 py-3 text-left font-medium">Mark</th>
                                                <th class="px-5 py-3 text-center font-medium">Notes</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var perf in eventGroup.Performances)
                                            {
                                                <tr class="border-t border-gray-200/50 dark:border-gray-700/50 hover:bg-gray-200/30 dark:hover:bg-gray-700/30 transition-colors">
                                                    <td class="px-5 py-3">
                                                        @if (IsRelay(perf.AthleteName))
                                                        {
                                                            <div class="space-y-1">
                                                                @foreach (var athlete in GetRelayAthletes(perf.AthleteName))
                                                                {
                                                                    var split = athlete.Split(' ');
                                                                    if (split.Length >= 2)
                                                                    {
                                                                        var firstName = split[0];
                                                                        var lastName = split[1];
                                                                        var helper = new SlugHelper();
                                                                        var slug = helper.GenerateSlug($"{firstName}-{lastName}");
                                                                        
                                                                        <div class="text-gray-900 dark:text-white">
                                                                            <span class="mr-2">•</span>
                                                                            <a asp-controller="Roster" asp-action="Details" asp-route-slug="@slug" class="underline">
                                                                                @athlete
                                                                            </a>
                                                                        </div>
                                                                    }
                                                                }
                                                            </div>
                                                        }
                                                        else
                                                        {
                                                            var split = perf.AthleteName.Split(' ');
                                                            if (split.Length >= 2)
                                                            {
                                                                var firstName = split[0];
                                                                var lastName = split[1];
                                                                var helper = new SlugHelper();
                                                                var slug = helper.GenerateSlug($"{firstName}-{lastName}");

                                                                <a asp-controller="Roster" asp-action="Details" asp-route-slug="@slug" class="text-gray-900 dark:text-white underline">
                                                                    @perf.AthleteName
                                                                </a>
                                                            }
                                                            else
                                                            {
                                                                <span class="text-gray-900 dark:text-white">@perf.AthleteName</span>
                                                            }
                                                        }
                                                    </td>
                                                    <td class="px-5 py-3">
                                                        <span class="font-mono font-semibold text-lg text-gray-900 dark:text-white">@perf.Performance</span>
                                                    </td>
                                                    <td class="px-5 py-3">
                                                        <div class="flex justify-center gap-2 flex-wrap">
                                                            @if (perf.IsSchoolRecord)
                                                            {
                                                                <span class="inline-block px-2 py-1 text-xs font-semibold rounded bg-yellow-50 dark:bg-yellow-900/20 text-yellow-800 dark:text-yellow-200 border border-yellow-200 dark:border-yellow-700/30" title="School Record">
                                                                    SR
                                                                </span>
                                                            }
                                                            @if (perf.IsPersonalBest)
                                                            {
                                                                <span class="inline-block px-2 py-1 text-xs font-semibold rounded bg-green-50 dark:bg-green-900/20 text-green-800 dark:text-green-200 border border-green-200 dark:border-green-700/30" title="Personal Best">
                                                                    PR
                                                                </span>
                                                            }
                                                            @if (perf.IsSeasonBest)
                                                            {
                                                                <span class="inline-block px-2 py-1 text-xs font-semibold rounded bg-blue-50 dark:bg-blue-900/20 text-blue-800 dark:text-blue-200 border border-blue-200 dark:border-blue-700/30" title="Season Best">
                                                                    SB
                                                                </span>
                                                            }
                                                            @if (perf.AllTimeRank.HasValue && perf.AllTimeRank <= 10)
                                                            {
                                                                <span class="inline-block px-2 py-1 text-xs font-semibold rounded bg-purple-50 dark:bg-purple-900/20 text-purple-800 dark:text-purple-200 border border-purple-200 dark:border-purple-700/30" title="All-Time Top 10">
                                                                    #@perf.AllTimeRank AT
                                                                </span>
                                                            }
                                                            @foreach (var placing in perf.Placings)
                                                            {
                                                                <span class="inline-flex items-center gap-1 px-2 py-1 text-xs font-semibold rounded bg-orange-50 dark:bg-orange-900/20 text-orange-800 dark:text-orange-200 border border-orange-200 dark:border-orange-700/30"
                                                                      title="@(placing.OpponentSchoolName != null ? $"Place vs. {placing.OpponentSchoolName}" : "Place")">
                                                                    @placing.MedalEmoji@(placing.OpponentSchoolName != null ? $" vs. {placing.OpponentSchoolName}" : "")
                                                                </span>
                                                            }
                                                        </div>
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }
        }
        else
        {
            <div class="p-8 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl text-center">
                <p class="text-gray-600 dark:text-gray-400">No girls results for this meet.</p>
            </div>
        }
        </div>
    </div>

    @if (Model.MixedEvents.Any())
    {
        <!-- Mixed Relay Results -->
        <div class="mt-12">
            <h2 class="text-2xl font-bold mb-6 text-purple-600 dark:text-purple-400 flex items-center gap-2">
                <span>⚥</span>
                <span>Mixed Relays</span>
            </h2>

            @{
                var mixedGrouped = Model.MixedEvents.GroupBy(e => e.EventCategory);
            }
            @foreach (var categoryGroup in mixedGrouped)
            {
                <div class="mb-8">
                    <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-4">@GetCategoryName(categoryGroup.Key)</h3>

                    <div class="space-y-4">
                        @foreach (var eventGroup in categoryGroup)
                        {
                            <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl overflow-hidden">
                                <div class="bg-purple-50 dark:bg-purple-900/20 border-b border-purple-200 dark:border-purple-700/30 px-5 py-3">
                                    <h4 class="text-lg font-semibold text-purple-900 dark:text-purple-300">@eventGroup.EventName</h4>
                                </div>

                                <div class="overflow-x-auto">
                                    <table class="min-w-full text-sm">
                                        <thead class="border-b border-gray-200 dark:border-gray-700">
                                            <tr class="text-gray-600 dark:text-gray-400 text-xs">
                                                <th class="px-5 py-3 text-left font-medium">Athlete</th>
                                                <th class="px-5 py-3 text-left font-medium">Mark</th>
                                                <th class="px-5 py-3 text-center font-medium">Notes</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var perf in eventGroup.Performances)
                                            {
                                                <tr class="border-t border-gray-200/50 dark:border-gray-700/50 hover:bg-gray-200/30 dark:hover:bg-gray-700/30 transition-colors">
                                                    <td class="px-5 py-3">
                                                        @if (IsRelay(perf.AthleteName))
                                                        {
                                                            <div class="space-y-1">
                                                                @foreach (var athlete in GetRelayAthletes(perf.AthleteName))
                                                                {
                                                                    var split = athlete.Split(' ');
                                                                    if (split.Length >= 2)
                                                                    {
                                                                        var firstName = split[0];
                                                                        var lastName = split[1];
                                                                        var helper = new SlugHelper();
                                                                        var slug = helper.GenerateSlug($"{firstName}-{lastName}");

                                                                        <div class="text-gray-900 dark:text-white">
                                                                            <span class="mr-2">•</span>
                                                                            <a asp-controller="Roster" asp-action="Details" asp-route-slug="@slug" class="underline">
                                                                                @athlete
                                                                            </a>
                                                                        </div>
                                                                    }
                                                                }
                                                            </div>
                                                        }
                                                        else
                                                        {
                                                            var split = perf.AthleteName.Split(' ');
                                                            if (split.Length >= 2)
                                                            {
                                                                var firstName = split[0];
                                                                var lastName = split[1];
                                                                var helper = new SlugHelper();
                                                                var slug = helper.GenerateSlug($"{firstName}-{lastName}");

                                                                <a asp-controller="Roster" asp-action="Details" asp-route-slug="@slug" class="text-gray-900 dark:text-white underline">
                                                                    @perf.AthleteName
                                                                </a>
                                                            }
                                                            else
                                                            {
                                                                <span class="text-gray-900 dark:text-white">@perf.AthleteName</span>
                                                            }
                                                        }
                                                    </td>
                                                    <td class="px-5 py-3">
                                                        <span class="font-mono font-semibold text-lg text-gray-900 dark:text-white">@perf.Performance</span>
                                                    </td>
                                                    <td class="px-5 py-3">
                                                        <div class="flex justify-center gap-2 flex-wrap">
                                                            @if (perf.IsSchoolRecord)
                                                            {
                                                                <span class="inline-block px-2 py-1 text-xs font-semibold rounded bg-yellow-50 dark:bg-yellow-900/20 text-yellow-800 dark:text-yellow-200 border border-yellow-200 dark:border-yellow-700/30" title="School Record">
                                                                    SR
                                                                </span>
                                                            }
                                                            @if (perf.IsPersonalBest)
                                                            {
                                                                <span class="inline-block px-2 py-1 text-xs font-semibold rounded bg-green-50 dark:bg-green-900/20 text-green-800 dark:text-green-200 border border-green-200 dark:border-green-700/30" title="Personal Best">
                                                                    PR
                                                                </span>
                                                            }
                                                            @if (perf.IsSeasonBest)
                                                            {
                                                                <span class="inline-block px-2 py-1 text-xs font-semibold rounded bg-blue-50 dark:bg-blue-900/20 text-blue-800 dark:text-blue-200 border border-blue-200 dark:border-blue-700/30" title="Season Best">
                                                                    SB
                                                                </span>
                                                            }
                                                            @if (perf.AllTimeRank.HasValue && perf.AllTimeRank <= 10)
                                                            {
                                                                <span class="inline-block px-2 py-1 text-xs font-semibold rounded bg-purple-50 dark:bg-purple-900/20 text-purple-800 dark:text-purple-200 border border-purple-200 dark:border-purple-700/30" title="All-Time Top 10">
                                                                    #@perf.AllTimeRank AT
                                                                </span>
                                                            }
                                                            @foreach (var placing in perf.Placings)
                                                            {
                                                                <span class="inline-flex items-center gap-1 px-2 py-1 text-xs font-semibold rounded bg-orange-50 dark:bg-orange-900/20 text-orange-800 dark:text-orange-200 border border-orange-200 dark:border-orange-700/30"
                                                                      title="@(placing.OpponentSchoolName != null ? $"Place vs. {placing.OpponentSchoolName}" : "Place")">
                                                                    @placing.MedalEmoji@(placing.OpponentSchoolName != null ? $" vs. {placing.OpponentSchoolName}" : "")
                                                                </span>
                                                            }
                                                        </div>
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    }

</div>
