@using Slugify
@model MeetDetailsViewModel

@{
    ViewBag.Title = Model.Name;
}

@functions {
    bool IsRelay(string athleteName) => athleteName?.Contains("|~|") ?? false;

    string[] GetRelayAthletes(string athleteName) =>
        athleteName?.Split("|~|") ?? Array.Empty<string>();

    string GetCategoryName(CloverleafTrack.Models.Enums.EventCategory category) => category switch
    {
        CloverleafTrack.Models.Enums.EventCategory.Sprints  => "Sprints",
        CloverleafTrack.Models.Enums.EventCategory.Distance => "Distance",
        CloverleafTrack.Models.Enums.EventCategory.Throws   => "Throws",
        CloverleafTrack.Models.Enums.EventCategory.Jumps    => "Jumps",
        CloverleafTrack.Models.Enums.EventCategory.Relays   => "Relays",
        CloverleafTrack.Models.Enums.EventCategory.Hurdles  => "Hurdles",
        _ => "Other"
    };

    string AthleteSlug(string name)
    {
        var parts = name?.Split(' ');
        if (parts?.Length >= 2)
        {
            var helper = new SlugHelper();
            return helper.GenerateSlug($"{parts[0]}-{parts[1]}");
        }
        return string.Empty;
    }
}

<div class="max-w-7xl mx-auto px-4 sm:px-6">

    <!-- Header -->
    <div class="mb-6">
        <a asp-controller="Meets" asp-action="Index" class="text-sm text-gray-500 dark:text-gray-400 hover:underline mb-3 inline-block">
            ← Meets
        </a>
        <h1 class="text-3xl font-bold text-gray-900 dark:text-white">@Model.Name</h1>

        <div class="flex flex-wrap gap-x-4 gap-y-1 text-sm text-gray-500 dark:text-gray-400 mt-2">
            <span>@Model.Date.ToString("MMMM d, yyyy")</span>
            <span>@Model.SeasonName season</span>
            @{
                var loc = string.Join(", ", new[] { Model.LocationName, Model.LocationCity, Model.LocationState }.Where(s => !string.IsNullOrEmpty(s)));
            }
            @if (!string.IsNullOrEmpty(loc)) { <span>@loc</span> }
            <span class="chip-place">@(Model.Environment == CloverleafTrack.Models.Enums.Environment.Indoor ? "Indoor" : "Outdoor")</span>
            @if (Model.HandTimed) { <span class="chip-rank">Hand-timed</span> }
        </div>
    </div>

    <!-- Impact strip -->
    <div class="mb-8">
        <div class="metric-strip">
            <div class="metric-cell">
                <span class="metric-value">@Model.TotalPerformances</span>
                <span class="metric-label">Performances</span>
            </div>
            <div class="metric-cell">
                <span class="metric-value text-pr">@Model.TotalPRs</span>
                <span class="metric-label">PRs</span>
            </div>
            <div class="metric-cell">
                <span class="metric-value text-sr">@Model.TotalSchoolRecords</span>
                <span class="metric-label">Records</span>
            </div>
            <div class="metric-cell">
                <span class="metric-value">@Model.TopTenAllTimeCount</span>
                <span class="metric-label">Top-10</span>
            </div>
        </div>
    </div>

    <!-- Results by gender -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">

        <!-- Boys -->
        <div>
            <h2 class="text-lg font-bold mb-4 text-blue-600 dark:text-blue-400">Boys</h2>
            @if (Model.BoysEvents.Any())
            {
                @foreach (var catGroup in Model.BoysEvents.GroupBy(e => e.EventCategory))
                {
                    <div class="mb-6">
                        <h3 class="text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-2">@GetCategoryName(catGroup.Key)</h3>
                        @foreach (var eventGroup in catGroup)
                        {
                            <div class="mb-3 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg overflow-hidden">
                                <div class="px-4 py-2 bg-blue-50 dark:bg-blue-900/10 border-b border-blue-100 dark:border-blue-900/20">
                                    <h4 class="font-medium text-blue-900 dark:text-blue-300 text-sm">@eventGroup.EventName</h4>
                                </div>
                                <table class="w-full text-sm">
                                    <tbody class="divide-y divide-gray-100 dark:divide-gray-800">
                                        @foreach (var perf in eventGroup.Performances)
                                        {
                                            var rowClass = perf.IsSchoolRecord ? "row-sr" : (perf.IsPersonalBest ? "row-pr" : "");
                                            <tr class="@rowClass hover:bg-gray-50 dark:hover:bg-gray-700/30 transition-colors">
                                                <td class="px-4 py-2">
                                                    @if (IsRelay(perf.AthleteName))
                                                    {
                                                        <div class="text-gray-900 dark:text-white text-xs leading-relaxed">
                                                            @string.Join(" / ", GetRelayAthletes(perf.AthleteName).Select(a => {
                                                                var slug = AthleteSlug(a);
                                                                return string.IsNullOrEmpty(slug) ? a : a; // Rendered in loop below
                                                            }))
                                                        </div>
                                                        @* Relay: linked names *@
                                                        <div class="text-xs text-gray-700 dark:text-gray-300 leading-relaxed">
                                                            @{
                                                                var members = GetRelayAthletes(perf.AthleteName);
                                                                for (int ri = 0; ri < members.Length; ri++)
                                                                {
                                                                    var a = members[ri];
                                                                    var slug = AthleteSlug(a);
                                                                    if (!string.IsNullOrEmpty(slug))
                                                                    {
                                                                        <a asp-controller="Roster" asp-action="Details" asp-route-slug="@slug" class="hover:underline">@a</a>
                                                                    }
                                                                    else { @a }
                                                                    if (ri < members.Length - 1) { <span> / </span> }
                                                                }
                                                            }
                                                        </div>
                                                    }
                                                    else
                                                    {
                                                        var slug = AthleteSlug(perf.AthleteName);
                                                        if (!string.IsNullOrEmpty(slug))
                                                        {
                                                            <a asp-controller="Roster" asp-action="Details" asp-route-slug="@slug"
                                                               class="text-gray-900 dark:text-white hover:underline">@perf.AthleteName</a>
                                                        }
                                                        else
                                                        {
                                                            <span class="text-gray-900 dark:text-white">@perf.AthleteName</span>
                                                        }
                                                    }
                                                </td>
                                                <td class="px-4 py-2 text-right whitespace-nowrap">
                                                    <span class="mark font-semibold @(perf.IsSchoolRecord ? "text-sr" : (perf.IsPersonalBest ? "text-pr" : "text-gray-900 dark:text-white"))">@perf.Performance</span>
                                                </td>
                                                <td class="px-4 py-2 text-right">
                                                    <div class="flex items-center justify-end gap-1 flex-wrap">
                                                        @if (perf.IsSchoolRecord) { <span class="chip-sr" title="School Record">SR</span> }
                                                        @if (perf.IsPersonalBest) { <span class="chip-pr" title="Personal Best">PR</span> }
                                                        @if (perf.IsSeasonBest && !perf.IsPersonalBest) { <span class="chip-rank" title="Season Best">SB</span> }
                                                        @if (perf.AllTimeRank.HasValue && perf.AllTimeRank <= 10)
                                                        {
                                                            <span class="chip-rank" title="All-Time Top 10">#@perf.AllTimeRank</span>
                                                        }
                                                        @foreach (var placing in perf.Placings)
                                                        {
                                                            <span class="chip-place" title="@(placing.OpponentSchoolName != null ? $"vs. {placing.OpponentSchoolName}" : "Place")">
                                                                @placing.PlaceLabel@(placing.OpponentSchoolName != null ? $" vs. {placing.OpponentSchoolName}" : "")
                                                            </span>
                                                        }
                                                    </div>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                    </div>
                }
            }
            else
            {
                <p class="text-sm text-gray-500 dark:text-gray-400">No boys results for this meet.</p>
            }
        </div>

        <!-- Girls -->
        <div>
            <h2 class="text-lg font-bold mb-4 text-pink-600 dark:text-pink-400">Girls</h2>
            @if (Model.GirlsEvents.Any())
            {
                @foreach (var catGroup in Model.GirlsEvents.GroupBy(e => e.EventCategory))
                {
                    <div class="mb-6">
