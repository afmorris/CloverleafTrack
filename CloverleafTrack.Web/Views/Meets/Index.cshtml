@model MeetsIndexViewModel

@{
    ViewData["Title"] = "Meets";
}

<div class="max-w-7xl mx-auto px-6">

    <div class="mb-8">
        <h1 class="text-4xl font-bold text-gray-900 dark:text-white">Meets</h1>
        <p class="text-lg text-gray-600 dark:text-gray-400 mt-2">Complete meet history across all seasons</p>
    </div>

    @await Html.PartialAsync("_MeetsOverallStats", Model)

    <!-- Filter chips -->
    <div class="flex flex-wrap gap-x-6 gap-y-3 mb-6 p-4 bg-white dark:bg-gray-800 rounded-lg border border-gray-200 dark:border-gray-700">
        @await Html.PartialAsync("_FilterChipGroup", null, new ViewDataDictionary(ViewData) {
            ["Label"] = "Environment",
            ["FilterKey"] = "env",
            ["Options"] = new List<(string, string)> { ("outdoor", "☀️ Outdoor"), ("indoor", "🏢 Indoor") }
        })
    </div>

    @await Html.PartialAsync("_MeetsSeasonsList", Model.Seasons)

</div>
