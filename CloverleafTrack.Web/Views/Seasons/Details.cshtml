@model SeasonDetailsViewModel

@{
    ViewBag.Title = $"{Model.Name} Season";

    var maleIndoor = Model.IndoorTopPerformances.Where(p => p.Gender == Gender.Male).ToList();
    var femaleIndoor = Model.IndoorTopPerformances.Where(p => p.Gender == Gender.Female).ToList();
    var maleOutdoor = Model.OutdoorTopPerformances.Where(p => p.Gender == Gender.Male).ToList();
    var femaleOutdoor = Model.OutdoorTopPerformances.Where(p => p.Gender == Gender.Female).ToList();

    var hasIndoor = maleIndoor.Any() || femaleIndoor.Any();
    var hasOutdoor = maleOutdoor.Any() || femaleOutdoor.Any();
}

<!-- Main Content -->
<div class="max-w-7xl mx-auto px-6">

    <!-- Header -->
    <div class="mb-8">
        <a asp-controller="Seasons" asp-action="Index" class="text-gray-600 dark:text-gray-400 text-sm mb-2 inline-block">
            ← Back to All Seasons
        </a>
        <div class="flex flex-wrap items-center gap-4">
            <h1 class="text-4xl font-bold text-gray-900 dark:text-white">@Model.Name Season</h1>
            @if (Model.ScoringEnabled)
            {
                <a asp-controller="Seasons" asp-action="Scoring" asp-route-name="@Model.Name"
                   class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-orange-600 hover:bg-orange-700 text-white text-sm font-semibold transition-colors">
                    🏆 Season Scoring
                </a>
            }
        </div>
    </div>

    <!-- Summary Stats -->
    <div class="mb-12">
        <h2 class="text-2xl font-bold mb-6 text-gray-900 dark:text-white">Season Overview</h2>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
            <div class="bg-white dark:bg-gray-800 rounded-xl p-6 border border-purple-200 dark:border-purple-700/30">
                <div class="text-sm text-purple-700 dark:text-purple-300 mb-2 font-semibold uppercase tracking-wide">Total PRs</div>
                <div class="text-4xl font-bold text-purple-900 dark:text-purple-100">@Model.TotalPRs</div>
            </div>
            <div class="bg-white dark:bg-gray-800 rounded-xl p-6 border border-blue-200 dark:border-blue-700/30">
                <div class="text-sm text-blue-700 dark:text-blue-300 mb-2 font-semibold uppercase tracking-wide">Athletes with PRs</div>
                <div class="text-4xl font-bold text-blue-900 dark:text-blue-100">@Model.TotalAthletesWithPRs</div>
            </div>
            <div class="bg-white dark:bg-gray-800 rounded-xl p-6 border border-yellow-200 dark:border-yellow-700/30">
                <div class="text-sm text-yellow-700 dark:text-yellow-300 mb-2 font-semibold uppercase tracking-wide">School Records</div>
                <div class="text-4xl font-bold text-yellow-900 dark:text-yellow-100">@Model.TotalSchoolRecordsBroken</div>
            </div>
            <div class="bg-white dark:bg-gray-800 rounded-xl p-6 border border-green-200 dark:border-green-700/30">
                <div class="text-sm text-green-700 dark:text-green-300 mb-2 font-semibold uppercase tracking-wide">Meets</div>
                <div class="text-4xl font-bold text-green-900 dark:text-green-100">@Model.TotalMeets</div>
            </div>
        </div>
    </div>

    <!-- Top Performances Section -->
    @if (hasIndoor || hasOutdoor)
    {
        <section class="mb-16">

            <div class="mb-6 flex items-start justify-between flex-wrap gap-4">
                <div>
                    <h2 class="text-2xl font-bold text-gray-900 dark:text-white">Top 10 All-Time Performances</h2>
                    <p class="text-gray-600 dark:text-gray-400">Performances entering or improving a Top 10 All-Time List this season</p>
                </div>
                <div class="filter-group inline-flex bg-gray-100 dark:bg-gray-800 rounded-xl p-1 border border-gray-200 dark:border-gray-700"
                     data-filter-key="env"
                     role="group"
                     aria-label="Environment">
                    <button type="button" data-value="outdoor" aria-pressed="false"
                            class="filter-chip-inactive px-4 py-1.5 rounded-lg text-sm font-semibold transition-all focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-1">
                        Outdoor
                    </button>
                    <button type="button" data-value="indoor" aria-pressed="false"
                            class="filter-chip-inactive px-4 py-1.5 rounded-lg text-sm font-semibold transition-all focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-1">
                        Indoor
                    </button>
                </div>
            </div>

                <!-- Outdoor Content -->
                <div data-filterable data-env="outdoor" class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 mb-4 p-8">
                    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
                        <!-- Boys Outdoor -->
                        <div class="bg-gray-100 dark:bg-gray-800 border border-gray-500 dark:border-gray-700 rounded-xl p-6">
                            <h3 class="text-xl font-bold text-blue-600 dark:text-blue-400 mb-4 flex items-center gap-2">
                                <span>♂</span>
                                <span>Boys Outdoor</span>
                            </h3>

                            @if (maleOutdoor.Any())
                            {
                                <div class="overflow-x-auto">
                                    <table class="min-w-full text-sm">
                                        <thead class="text-left border-b border-gray-700">
                                            <tr class="text-gray-600 dark:text-gray-400 text-xs">
                                                <th class="pb-3 pr-4 font-medium">Event</th>
                                                <th class="pb-3 pr-4 font-medium">Athlete</th>
                                                <th class="pb-3 pr-4 font-medium">Mark</th>
                                                <th class="pb-3 pr-4 font-medium">Rank</th>
                                                <th class="pb-3 font-medium">Meet</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var perf in maleOutdoor)
                                            {
                                                <tr class="border-t border-gray-700/50 hover:bg-gray-700/30 transition-colors">
                                                    <td class="py-3 pr-4 text-gray-900 dark:text-white">@perf.EventName</td>
                                                    <td class="py-3 pr-4 text-gray-600 dark:text-gray-300">
                                                        <a class="underline" asp-controller="Roster" asp-action="Details" asp-route-slug="@perf.AthleteSlug">
                                                            @perf.AthleteName
                                                        </a>
                                                    </td>
                                                    <td class="py-3 pr-4 font-semibold text-yellow-900 dark:text-yellow-100">@perf.Performance</td>
                                                    <td class="py-3 pr-4 text-gray-600 dark:text-gray-400">@perf.AllTimeRank</td>
                                                    <td class="py-3 text-xs text-gray-600 dark:text-gray-400">
                                                        <div>
                                                            <a class="underline" asp-controller="Meets" asp-action="Details" asp-route-slug="@perf.MeetSlug">
                                                                @perf.MeetName
                                                            </a>
                                                        </div>
                                                        <div class="text-gray-500">@perf.MeetDate.ToString("MMM d, yyyy")</div>
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            }
                            else
                            {
                                <p class="text-gray-400 text-sm italic">No boys outdoor top 10 performances this season.</p>
                            }
                        </div>

                        <!-- Girls Outdoor -->
                        <div class="bg-gray-100 dark:bg-gray-800 border border-gray-500 dark:border-gray-700 rounded-xl p-6">
                            <h3 class="text-xl font-bold text-pink-600 dark:text-pink-400 mb-4 flex items-center gap-2">
                                <span>♀</span>
                                <span>Girls Outdoor</span>
                            </h3>

                            @if (femaleOutdoor.Any())
                            {
                                <div class="overflow-x-auto">
                                    <table class="min-w-full text-sm">
                                        <thead class="text-left border-b border-gray-700">
                                            <tr class="text-gray-600 dark:text-gray-400 text-xs">
                                                <th class="pb-3 pr-4 font-medium">Event</th>
                                                <th class="pb-3 pr-4 font-medium">Athlete</th>
                                                <th class="pb-3 pr-4 font-medium">Mark</th>
                                                <th class="pb-3 pr-4 font-medium">Rank</th>
                                                <th class="pb-3 font-medium">Meet</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var perf in femaleOutdoor)
                                            {
                                                <tr class="border-t border-gray-700/50 hover:bg-gray-700/30 transition-colors">
                                                    <td class="py-3 pr-4 text-gray-900 dark:text-white">@perf.EventName</td>
                                                    <td class="py-3 pr-4 text-gray-600 dark:text-gray-300">
                                                        <a class="underline" asp-controller="Roster" asp-action="Details" asp-route-slug="@perf.AthleteSlug">
                                                            @perf.AthleteName
                                                        </a>
                                                    </td>
                                                    <td class="py-3 pr-4 font-semibold text-yellow-900 dark:text-yellow-100">@perf.Performance</td>
                                                    <td class="py-3 pr-4 text-gray-600 dark:text-gray-400">@perf.AllTimeRank</td>
                                                    <td class="py-3 text-xs text-gray-600 dark:text-gray-400">
                                                        <div>
                                                            <a class="underline" asp-controller="Meets" asp-action="Details" asp-route-slug="@perf.MeetSlug">
                                                                @perf.MeetName
                                                            </a>
                                                        </div>
                                                        <div class="text-gray-500">@perf.MeetDate.ToString("MMM d, yyyy")</div>
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            }
                            else
                            {
                                <p class="text-gray-400 text-sm italic">No girls outdoor top 10 performances this season.</p>
                            }
                        </div>
                    </div>
                </div>

                <!-- Indoor Content -->
                <div data-filterable data-env="indoor" class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 mb-4 p-8">
                    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
                        <!-- Boys Indoor -->
                        <div class="bg-gray-100 dark:bg-gray-800 border border-gray-500 dark:border-gray-700 rounded-xl p-6">
                            <h3 class="text-xl font-bold text-blue-600 dark:text-blue-400 mb-4 flex items-center gap-2">
                                <span>♂</span>
                                <span>Boys Indoor</span>
                            </h3>

                            @if (maleIndoor.Any())
                            {
                                <div class="overflow-x-auto">
                                    <table class="min-w-full text-sm">
                                        <thead class="text-left border-b border-gray-700">
                                            <tr class="text-gray-600 dark:text-gray-400 text-xs">
                                                <th class="pb-3 pr-4 font-medium">Event</th>
                                                <th class="pb-3 pr-4 font-medium">Athlete</th>
                                                <th class="pb-3 pr-4 font-medium">Mark</th>
                                                <th class="pb-3 pr-4 font-medium">Rank</th>
                                                <th class="pb-3 font-medium">Meet</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var perf in maleIndoor)
                                            {
                                                <tr class="border-t border-gray-700/50 hover:bg-gray-300/30 dark:hover:bg-gray-700/30 transition-colors">
                                                    <td class="py-3 pr-4 text-gray-900 dark:text-white">@perf.EventName</td>
                                                    <td class="py-3 pr-4 text-gray-600 dark:text-gray-300">
                                                        <a class="underline" asp-controller="Roster" asp-action="Details" asp-route-slug="@perf.AthleteSlug">
                                                            @perf.AthleteName
                                                        </a>
                                                    </td>
                                                    <td class="py-3 pr-4 font-semibold text-blue-600 dark:text-blue-400">@perf.Performance</td>
                                                    <td class="py-3 pr-4 text-gray-600 dark:text-gray-400">@perf.AllTimeRank</td>
                                                    <td class="py-3 text-xs text-gray-600 dark:text-gray-400">
                                                        <div>
                                                            <a class="underline" asp-controller="Meets" asp-action="Details" asp-route-slug="@perf.MeetSlug">
                                                                @perf.MeetName
                                                            </a>
                                                        </div>
                                                        <div class="text-gray-500">@perf.MeetDate.ToString("MMM d, yyyy")</div>
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            }
                            else
                            {
                                <p class="text-gray-400 text-sm italic">No boys indoor top 10 performances this season.</p>
                            }
                        </div>

                        <!-- Girls Indoor -->
                        <div class="bg-gray-100 dark:bg-gray-800 border border-gray-500 dark:border-gray-700 rounded-xl p-6">
                            <h3 class="text-xl font-bold text-pink-600 dark:text-pink-400 mb-4 flex items-center gap-2">
                                <span>♀</span>
                                <span>Girls Indoor</span>
                            </h3>

                            @if (femaleIndoor.Any())
                            {
                                <div class="overflow-x-auto">
                                    <table class="min-w-full text-sm">
                                        <thead class="text-left border-b border-gray-700">
                                            <tr class="text-gray-600 dark:text-gray-400 text-xs">
                                                <th class="pb-3 pr-4 font-medium">Event</th>
                                                <th class="pb-3 pr-4 font-medium">Athlete</th>
                                                <th class="pb-3 pr-4 font-medium">Mark</th>
                                                <th class="pb-3 pr-4 font-medium">Rank</th>
                                                <th class="pb-3 font-medium">Meet</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var perf in femaleIndoor)
                                            {
                                                <tr class="border-t border-gray-700/50 hover:bg-gray-700/30 transition-colors">
                                                    <td class="py-3 pr-4 text-gray-900 dark:text-white">@perf.EventName</td>
                                                    <td class="py-3 pr-4 text-gray-600 dark:text-gray-300">
                                                        <a class="underline" asp-controller="Roster" asp-action="Details" asp-route-slug="@perf.AthleteSlug">
                                                            @perf.AthleteName
                                                        </a>
                                                    </td>
                                                    <td class="py-3 pr-4 font-semibold text-blue-600 dark:text-blue-400">@perf.Performance</td>
                                                    <td class="py-3 pr-4 text-gray-600 dark:text-gray-400">@perf.AllTimeRank</td>
                                                    <td class="py-3 text-xs text-gray-600 dark:text-gray-400">
                                                        <div>
                                                            <a class="underline" asp-controller="Meets" asp-action="Details" asp-route-slug="@perf.MeetSlug">
                                                                @perf.MeetName
                                                            </a>
                                                        </div>
                                                        <div class="text-gray-500">@perf.MeetDate.ToString("MMM d, yyyy")</div>
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            }
                            else
                            {
                                <p class="text-gray-400 text-sm italic">No girls indoor top 10 performances this season.</p>
                            }
                        </div>
                    </div>
                </div>

        </section>
    }
    else
    {
        <div class="mb-12 p-6 bg-gray-800/50 border border-gray-700 rounded-xl">
            <p class="text-gray-400">No Top 10 All-Time Performances yet this season.</p>
        </div>
    }

    <!-- Meets Section -->
    <div class="mb-12">
        <h2 class="text-2xl font-bold mb-6 text-gray-900 dark:text-white">Season Meets</h2>
        <div class="space-y-3">
            @foreach (var meet in Model.Meets.OrderBy(m => m.MeetDate))
            {
                <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl p-5">
                    <div class="flex items-center gap-4">
                        <!-- Calendar Badge -->
                        <div class="flex flex-col items-center bg-gray-50 dark:bg-gray-700 border border-gray-200 dark:border-gray-600 rounded-lg px-3 py-2 min-w-[60px] text-center">
                            <div class="text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase">
                                @meet.MeetDate.ToString("MMM")
                            </div>
                            <div class="text-2xl font-bold text-gray-900 dark:text-white leading-tight">
                                @meet.MeetDate.Day
                            </div>
                        </div>

                        <!-- Meet Info -->
                        <div class="flex-1">
                            <div class="text-lg font-semibold text-gray-900 dark:text-white mb-1">
                                <a class="underline" asp-controller="Meets" asp-action="Details" asp-route-slug="@meet.Slug">
                                    @meet.MeetName
                                </a>
                            </div>
                            @if (!string.IsNullOrEmpty(meet.Location))
                            {
                                <div class="text-sm text-gray-600 dark:text-gray-400 mb-2">@meet.Location</div>
                            }
                            <div class="flex gap-4 text-sm">
                                @if (meet.PRCount > 0)
                                {
                                    <span class="text-green-900 dark:text-green-100">
                                        ● @meet.PRCount PR@(meet.PRCount > 1 ? "s" : "")
                                    </span>
                                }
                                @if (meet.SchoolRecordCount > 0)
                                {
                                    <span class="text-yellow-700 dark:text-yellow-300">
                                        ● @meet.SchoolRecordCount SR@(meet.SchoolRecordCount > 1 ? "s" : "")
                                    </span>
                                }
                            </div>
                        </div>

                        <!-- View Results Link -->
                        @if (!string.IsNullOrEmpty(meet.ResultsUrl))
                        {
                            <div>
                                <a asp-controller="Meets" asp-action="Details" asp-route-slug="@meet.Slug"
                                   class="px-4 py-2 dark:bg-blue-500/20 dark:text-blue-400 bg-blue-100 text-blue-700 rounded-lg border border-blue-500/30 text-sm font-medium">
                                    View Results →
                                </a>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    </div>

</div>

@section Scripts {
<script>
    (function () {
        var month = new Date().getMonth() + 1;
        var defaultEnv = (month >= 12 || month <= 2) ? 'indoor' : 'outdoor';
        var stored = localStorage.getItem('ctf.environment');
        var env = stored || defaultEnv;
        if (!location.hash || !location.hash.includes('env=')) {
            var hash = location.hash ? location.hash.slice(1) : '';
            var parts = hash ? hash.split('&').filter(function (p) { return !p.startsWith('env='); }) : [];
            parts.unshift('env=' + env);
            history.replaceState(null, '', '#' + parts.join('&'));
        }
        document.addEventListener('DOMContentLoaded', function () {
            document.querySelectorAll('.filter-group[data-filter-key="env"] button').forEach(function (btn) {
                btn.addEventListener('click', function () {
                    localStorage.setItem('ctf.environment', this.dataset.value);
                });
            });
        });
    }());
</script>
}