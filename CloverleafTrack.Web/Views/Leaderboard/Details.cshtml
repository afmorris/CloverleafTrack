@using Slugify
@model LeaderboardDetailsViewModel

@{
    ViewBag.Title = $"{Model.EventName}";
    var environmentLabel = Model.Environment == CloverleafTrack.Models.Enums.Environment.Outdoor ? "Outdoor" : "Indoor";
    var currentYear  = DateTime.Now.Year;
    var currentMonth = DateTime.Now.Month;
    var adjustedCurrentYear = currentMonth >= 6 ? currentYear + 1 : currentYear;
}

@functions {
    string GetClassYear(int? gradYear, int adjustedYear)
    {
        if (!gradYear.HasValue) return "";
        return (gradYear.Value - adjustedYear) switch
        {
            >= 3 => "Freshman",
            2    => "Sophomore",
            1    => "Junior",
            0    => "Senior",
            _    => $"'{gradYear.Value.ToString().Substring(2)}"
        };
    }

    string[] GetRelayAthletes(string athleteName) =>
        athleteName?.Split("|~|") ?? Array.Empty<string>();
}

<style>
    .sr-history-grid { display: grid; grid-template-columns: 2fr 3fr; }
    .sr-history-left { border-right: 1px solid #e5e7eb; }
    .dark .sr-history-left { border-right-color: #374151; }

    .timeline-track { position: relative; padding-left: 1.5rem; }
    .timeline-track::before { content: ''; position: absolute; left: 7px; top: 12px; bottom: 12px; width: 2px; background: #e5e7eb; }
    .dark .timeline-track::before { background: #374151; }
    .timeline-item { position: relative; padding-bottom: 0.75rem; }
    .timeline-item:last-child { padding-bottom: 0; }
    .timeline-dot { position: absolute; left: -1.5rem; top: 3px; width: 16px; height: 16px; border-radius: 50%; border: 2px solid white; }
    .dark .timeline-dot { border-color: #1f2937; }
    .timeline-dot-current { background: #f59e0b; box-shadow: 0 0 8px rgba(245, 158, 11, 0.5); }
    .timeline-dot-past { background: #9ca3af; }
    .dark .timeline-dot-past { background: #4b5563; }
</style>

<div class="max-w-7xl mx-auto px-6">

    <!-- Header -->
    <div class="mb-8">
        <a asp-controller="Leaderboard" asp-action="Index" class="text-gray-600 dark:text-gray-400 text-sm mb-2 inline-block hover:underline">
            ← Back to Leaderboard
        </a>
        <h1 class="text-4xl font-bold text-gray-900 dark:text-white">
            @environmentLabel @Model.EventName
        </h1>
        <p class="text-gray-600 dark:text-gray-400 text-lg">
            @Model.GenderLabel @environmentLabel All-Time Rankings
        </p>
    </div>

    <!-- School Record History -->
    @if (Model.SchoolRecordProgression.Any())
    {
        var current = Model.SchoolRecordProgression.First();
        var first = Model.SchoolRecordProgression.Last();
        var timesBroken = Model.SchoolRecordProgression.Count - 1;

        <div class="mb-8 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl overflow-hidden">
            <details>
                <summary class="cursor-pointer list-none w-full flex items-center justify-between px-6 py-4 text-left hover:bg-gray-50 dark:hover:bg-gray-700/50 transition-colors">
                    <div class="flex items-center gap-3">
                        <div class="h-5 w-1 rounded-full bg-amber-500"></div>
                        <span class="font-semibold text-gray-900 dark:text-white">School Record History</span>
                        <span class="chip-sr">SR</span>
                        <span class="text-sm text-gray-500 dark:text-gray-400">
                            — broken @timesBroken time@(timesBroken == 1 ? "" : "s") since @first.MeetDate.Year
                        </span>
                    </div>
                    <svg class="details-arrow w-5 h-5 text-gray-400 flex-shrink-0 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                    </svg>
                </summary>

                <div class="border-t border-gray-200 dark:border-gray-700">
                    <div class="sr-history-grid">
                        <div class="sr-history-left px-6 py-5">
                            <p class="text-xs font-bold uppercase tracking-wider text-gray-500 dark:text-gray-400 mb-3">Record Holders</p>
                            <div class="timeline-track">
                                @foreach (var moment in Model.SchoolRecordProgression)
                                {
                                    var relayMembers2 = moment.AthleteName.Contains("|~|")
                                        ? moment.AthleteName.Split("|~|") : null;
                                    <div class="timeline-item">
                                        <div class="timeline-dot @(moment.IsCurrentRecord ? "timeline-dot-current" : "timeline-dot-past")"></div>
                                        <div>
                                            <div class="flex items-baseline gap-2 flex-wrap">
                                                @if (relayMembers2 != null)
                                                {
                                                    <span class="font-semibold text-gray-900 dark:text-gray-200 text-sm">@string.Join(" / ", relayMembers2)</span>
                                                }
                                                else
                                                {
                                                    <a asp-controller="Roster" asp-action="Details" asp-route-slug="@moment.AthleteSlug"
                                                       class="@(moment.IsCurrentRecord ? "font-bold text-gray-900 dark:text-white" : "font-semibold text-gray-700 dark:text-gray-300") text-sm underline">
                                                        @moment.AthleteName
                                                    </a>
                                                    @if (moment.GraduationYear.HasValue)
                                                    {
                                                        <span class="text-xs text-gray-500">'@(moment.GraduationYear.Value.ToString().Substring(2))</span>
                                                    }
                                                }
                                                @if (moment.IsCurrentRecord) { <span class="chip-sr">Current SR</span> }
                                            </div>
                                            <div class="@(moment.IsCurrentRecord ? "text-amber-500 dark:text-amber-400" : "text-gray-700 dark:text-gray-300") font-bold text-base mark">
                                                @moment.Performance
                                            </div>
                                            <div class="text-xs text-gray-500">@moment.MeetDate.ToString("MMM d, yyyy")</div>
                                            @if (moment.ImprovementFormatted != null)
                                            {
                                                <span class="text-xs font-bold px-1.5 py-0.5 rounded-full bg-green-900/30 text-green-400 border border-green-700/50 mt-1 inline-block">
                                                    @moment.ImprovementFormatted
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="text-xs text-gray-500 dark:text-gray-600">First recorded school record</span>
                                            }
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>

                        <div class="px-6 py-5 flex flex-col">
                            <div class="flex items-center justify-between mb-4">
                                <p class="text-xs font-bold uppercase tracking-wider text-gray-500 dark:text-gray-400">Record Progression</p>
                                <div class="flex items-center gap-2 text-xs text-gray-500">
                                    <span class="inline-block w-4 h-0.5 bg-amber-400 rounded"></span>
                                    School record at time
                                </div>
                            </div>
                            <div class="flex-1" style="min-height:240px;position:relative;">
                                <canvas id="srProgressionChart"
                                    data-labels="@System.Text.Json.JsonSerializer.Serialize(Model.SchoolRecordProgression.OrderBy(p => p.MeetDate).Select(p => p.MeetDate.Year.ToString()).ToList())"
                                    data-values="@System.Text.Json.JsonSerializer.Serialize(Model.SchoolRecordProgression.OrderBy(p => p.MeetDate).Select(p => p.RawValue).ToList())"
                                    data-names="@System.Text.Json.JsonSerializer.Serialize(Model.SchoolRecordProgression.OrderBy(p => p.MeetDate).Select(p => p.AthleteName).ToList())"
                                    data-perfs="@System.Text.Json.JsonSerializer.Serialize(Model.SchoolRecordProgression.OrderBy(p => p.MeetDate).Select(p => p.Performance).ToList())"
                                    data-isfield="@Model.IsFieldEvent.ToString().ToLower()">
                                </canvas>
                            </div>
                        </div>
                    </div>
                </div>
            </details>
        </div>
    }

    <!-- View Toggle -->
    <div class="mb-4 flex gap-3 flex-wrap">
        <button onclick="showView('all')" id="all-tab"
                class="pill-tab pill-tab-active">
            All Performances (@Model.AllPerformances.Count)
        </button>
        @if (!Model.IsRelayEvent)
        {
            <button onclick="showView('prs')" id="prs-tab" class="pill-tab">
                PRs Only (@Model.PersonalRecordsOnly.Count)
            </button>
        }
    </div>

    @if (!Model.IsRelayEvent)
    {
        <div class="mb-6 flex items-center gap-2 flex-wrap">
            <span class="text-sm font-semibold text-gray-500 dark:text-gray-400 mr-1">Class:</span>
            @foreach (var cls in new[] { ("all","All"), ("Freshman","Fr"), ("Sophomore","So"), ("Junior","Jr"), ("Senior","Sr") })
            {
                <button onclick="filterByClass('@cls.Item1')" id="class-@cls.Item1"
                        class="class-tab pill-tab @(cls.Item1 == "all" ? "pill-tab-active" : "")">
                    @cls.Item2
                </button>
            }
        </div>
    }

    <!-- All Performances -->
    <div id="all-content" class="view-content">
        <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl overflow-hidden">
            <div class="overflow-x-auto">
                <table id="all-table" class="min-w-full text-sm">
                    <thead class="bg-gray-50 dark:bg-gray-700/50">
                        <tr class="text-xs uppercase tracking-wide text-gray-500 dark:text-gray-400">
                            <th class="px-5 py-3 text-left font-medium w-14 cursor-pointer hover:bg-gray-100 dark:hover:bg-gray-700 select-none" data-sort-col="rank" data-sort-type="num">
                                Rank <span class="sort-ind">↕</span>
                            </th>
                            <th class="px-5 py-3 text-left font-medium cursor-pointer hover:bg-gray-100 dark:hover:bg-gray-700 select-none" data-sort-col="athlete" data-sort-type="str">
                                Athlete <span class="sort-ind">↕</span>
                            </th>
                            <th class="px-5 py-3 text-left font-medium hidden sm:table-cell">Class</th>
                            <th class="px-5 py-3 text-left font-medium cursor-pointer hover:bg-gray-100 dark:hover:bg-gray-700 select-none" data-sort-col="mark" data-sort-type="num">
                                Mark <span class="sort-ind">↕</span>
                            </th>
                            <th class="px-5 py-3 text-left font-medium hidden md:table-cell">Meet</th>
                            <th class="px-5 py-3 text-left font-medium cursor-pointer hover:bg-gray-100 dark:hover:bg-gray-700 select-none hidden sm:table-cell" data-sort-col="date" data-sort-type="num">
                                Date <span class="sort-ind">↕</span>
                            </th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-100 dark:divide-gray-700">
                        @foreach (var perf in Model.AllPerformances)
                        {
                            var isGold    = perf.Rank == 1;
                            var rowClass  = isGold
                                ? "bg-amber-50 dark:bg-amber-900/15 hover:bg-amber-100 dark:hover:bg-amber-900/25"
                                : "hover:bg-gray-50 dark:hover:bg-gray-700/30";
                            var srBorder  = perf.WasRecordAtTime ? "border-l-2 border-l-amber-400" : "";
                            var isStill   = perf.GraduationYear.HasValue && perf.GraduationYear.Value >= adjustedCurrentYear;
                            var isRelay   = perf.AthleteName.Contains("|~|");
                            <tr class="@rowClass @srBorder"
                                data-class="@(perf.ClassAtTimeOfPerformance ?? "")"
                                data-rank-val="@perf.Rank"
                                data-athlete-val="@perf.AthleteName"
                                data-mark-val="@(perf.RawValue?.ToString("F6", System.Globalization.CultureInfo.InvariantCulture) ?? "0")"
                                data-date-val="@perf.MeetDate.Ticks">
                                <td class="px-5 py-3 rank-cell w-14">
                                    <span class="text-xl font-bold tabular-nums @(isGold ? "text-amber-500" : perf.Rank <= 3 ? "text-amber-400" : "text-gray-400 dark:text-gray-500")">
                                        @perf.Rank
                                    </span>
                                </td>
                                <td class="px-5 py-3">
                                    @if (isRelay)
                                    {
                                        <div class="space-y-0.5">
                                            @foreach (var athlete in GetRelayAthletes(perf.AthleteName))
                                            {
                                                var split = athlete.Trim().Split(' ');
                                                if (split.Length >= 2)
                                                {
                                                    var slug = new SlugHelper().GenerateSlug($"{split[0]}-{split[1]}");
                                                    <div><a asp-controller="Roster" asp-action="Details" asp-route-slug="@slug" class="underline hover:text-ctf-darkaccent dark:hover:text-ctf-accent text-sm">@athlete</a></div>
                                                }
                                                else { <div class="text-sm text-gray-900 dark:text-white">@athlete</div> }
                                            }
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="flex items-center gap-1.5">
                                            @if (!string.IsNullOrEmpty(perf.AthleteSlug))
                                            {
                                                <a asp-controller="Roster" asp-action="Details" asp-route-slug="@perf.AthleteSlug"
                                                   class="font-medium text-gray-900 dark:text-white underline hover:text-ctf-darkaccent dark:hover:text-ctf-accent">
                                                    @perf.AthleteName
                                                </a>
                                            }
                                            else
                                            {
                                                <span class="font-medium text-gray-900 dark:text-white">@perf.AthleteName</span>
                                            }
                                            @if (isStill)
                                            {
                                                <span class="w-2 h-2 rounded-full bg-green-500 inline-block flex-shrink-0" title="Still competing" aria-label="Still competing"></span>
                                            }
                                        </div>
                                    }
                                </td>
                                <td class="px-5 py-3 text-gray-500 dark:text-gray-400 text-sm hidden sm:table-cell">
                                    @(perf.ClassAtTimeOfPerformance ?? "")
                                </td>
                                <td class="px-5 py-3">
                                    <div class="flex items-center gap-1.5 flex-wrap">
                                        <span class="mark font-bold text-gray-900 dark:text-white">@perf.Performance</span>
                                        @if (perf.IsSchoolRecord) { <span class="chip-sr">SR</span> }
                                        else if (perf.WasRecordAtTime) { <span class="chip-sr" style="opacity:0.5">SR</span> }
                                    </div>
                                </td>
                                <td class="px-5 py-3 hidden md:table-cell">
                                    <a asp-controller="Meets" asp-action="Details" asp-route-slug="@perf.MeetSlug"
                                       class="text-gray-600 dark:text-gray-400 underline hover:text-ctf-darkaccent dark:hover:text-ctf-accent text-sm">
                                        @perf.MeetName
                                    </a>
                                </td>
                                <td class="px-5 py-3 text-gray-500 dark:text-gray-400 text-sm hidden sm:table-cell">
                                    @perf.MeetDate.ToString("MMM d, yyyy")
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        @if (!Model.AllPerformances.Any())
        {
            <div class="p-8 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl text-center">
                <p class="text-gray-400">No performances recorded for this event yet.</p>
            </div>
        }
    </div>

    <!-- PRs Only -->
    <div id="prs-content" class="view-content hidden">
        @{
            var prSections = new[]
            {
                ("all",       Model.PersonalRecordsOnly),
                ("Freshman",  Model.ClassPersonalRecords.TryGetValue("Freshman",  out var fr)  ? fr  : new List<LeaderboardPerformanceViewModel>()),
                ("Sophomore", Model.ClassPersonalRecords.TryGetValue("Sophomore", out var so)  ? so  : new List<LeaderboardPerformanceViewModel>()),
                ("Junior",    Model.ClassPersonalRecords.TryGetValue("Junior",    out var jr)  ? jr  : new List<LeaderboardPerformanceViewModel>()),
                ("Senior",    Model.ClassPersonalRecords.TryGetValue("Senior",    out var sr2) ? sr2 : new List<LeaderboardPerformanceViewModel>()),
            };
        }
        @foreach (var (sectionKey, sectionPerfs) in prSections)
        {
            <div id="prs-section-@sectionKey" class="prs-section hidden">
                @if (sectionPerfs.Any())
                {
                    <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl overflow-hidden">
                        <div class="overflow-x-auto">
                            <table class="min-w-full text-sm">
                                <thead class="bg-gray-50 dark:bg-gray-700/50">
                                    <tr class="text-xs uppercase tracking-wide text-gray-500 dark:text-gray-400">
                                        <th class="px-5 py-3 text-left font-medium w-14">Rank</th>
                                        <th class="px-5 py-3 text-left font-medium">Athlete</th>
                                        <th class="px-5 py-3 text-left font-medium hidden sm:table-cell">Class</th>
                                        <th class="px-5 py-3 text-left font-medium">Mark</th>
                                        <th class="px-5 py-3 text-left font-medium hidden md:table-cell">Meet</th>
                                        <th class="px-5 py-3 text-left font-medium hidden sm:table-cell">Date</th>
                                    </tr>
                                </thead>
                                <tbody class="divide-y divide-gray-100 dark:divide-gray-700">
                                    @foreach (var perf in sectionPerfs)
                                    {
                                        var isGold2   = perf.Rank == 1;
                                        var rowClass2 = isGold2
                                            ? "bg-amber-50 dark:bg-amber-900/15 hover:bg-amber-100 dark:hover:bg-amber-900/25"
                                            : "hover:bg-gray-50 dark:hover:bg-gray-700/30";
                                        var isStill2  = perf.GraduationYear.HasValue && perf.GraduationYear.Value >= adjustedCurrentYear;
                                        <tr class="@rowClass2 @(perf.WasRecordAtTime ? "border-l-2 border-l-amber-400" : "")">
                                            <td class="px-5 py-3 w-14">
                                                <span class="text-xl font-bold tabular-nums @(isGold2 ? "text-amber-500" : perf.Rank <= 3 ? "text-amber-400" : "text-gray-400 dark:text-gray-500")">
                                                    @perf.Rank
                                                </span>
                                            </td>
                                            <td class="px-5 py-3">
                                                <div class="flex items-center gap-1.5">
                                                    @if (!string.IsNullOrEmpty(perf.AthleteSlug))
                                                    {
                                                        <a asp-controller="Roster" asp-action="Details" asp-route-slug="@perf.AthleteSlug"
                                                           class="font-medium text-gray-900 dark:text-white underline hover:text-ctf-darkaccent dark:hover:text-ctf-accent">
                                                            @perf.AthleteName
                                                        </a>
                                                    }
                                                    else
                                                    {
                                                        <span class="font-medium text-gray-900 dark:text-white">@perf.AthleteName</span>
                                                    }
                                                    @if (isStill2)
                                                    {
                                                        <span class="w-2 h-2 rounded-full bg-green-500 inline-block flex-shrink-0" title="Still competing" aria-label="Still competing"></span>
                                                    }
                                                </div>
                                            </td>
                                            <td class="px-5 py-3 text-gray-500 dark:text-gray-400 text-sm hidden sm:table-cell">@(perf.ClassAtTimeOfPerformance ?? "")</td>
                                            <td class="px-5 py-3">
                                                <div class="flex items-center gap-1.5 flex-wrap">
                                                    <span class="mark font-bold text-gray-900 dark:text-white">@perf.Performance</span>
                                                    @if (perf.IsSchoolRecord) { <span class="chip-sr">SR</span> }
                                                </div>
                                            </td>
                                            <td class="px-5 py-3 hidden md:table-cell">
                                                <a asp-controller="Meets" asp-action="Details" asp-route-slug="@perf.MeetSlug"
                                                   class="text-gray-600 dark:text-gray-400 underline hover:text-ctf-darkaccent dark:hover:text-ctf-accent text-sm">
                                                    @perf.MeetName
                                                </a>
                                            </td>
                                            <td class="px-5 py-3 text-gray-500 dark:text-gray-400 text-sm hidden sm:table-cell">@perf.MeetDate.ToString("MMM d, yyyy")</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                }
                else
                {
                    <div class="p-8 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl text-center">
                        <p class="text-gray-400">No personal records for this class yet.</p>
                    </div>
                }
            </div>
        }
    </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script>
    // SR chart
    let srChartBuilt = false;
    const srDetails = document.querySelector('.sr-history-grid')?.closest('details');
    if (srDetails) {
        srDetails.addEventListener('toggle', function () {
            if (this.open && !srChartBuilt) buildSrChart();
        });
    }

    function buildSrChart() {
        srChartBuilt = true;
        const canvas = document.getElementById('srProgressionChart');
        if (!canvas) return;
        const labels  = JSON.parse(canvas.dataset.labels);
        const values  = JSON.parse(canvas.dataset.values);
        const names   = JSON.parse(canvas.dataset.names);
        const perfs   = JSON.parse(canvas.dataset.perfs);
        const isField = canvas.dataset.isfield === 'true';

        function fmtInches(v) { const ft = Math.floor(v/12); const r = v%12; return `${ft}' ${r===0?'0':r.toFixed(2).replace(/\.?0+$/,'')}"`; }
        function fmtSecs(v)   { if(v>=60){const m=Math.floor(v/60);const s=v%60;return `${m}:${s.toFixed(2).padStart(5,'0')}`;} return `${v.toFixed(2)}`; }
        function displayName(raw) { return raw.includes('|~|') ? raw.split('|~|').join(' / ') : raw; }

        new Chart(canvas, {
            type: 'line',
            data: {
                labels,
                datasets: [{ data: values, borderColor: '#f59e0b', backgroundColor: 'rgba(245,158,11,0.07)', borderWidth: 2.5, stepped: 'before', fill: true, pointBackgroundColor: values.map((_,i)=>i===values.length-1?'#f59e0b':'#4b5563'), pointBorderColor: values.map((_,i)=>i===values.length-1?'#1f2937':'#f59e0b'), pointBorderWidth: 2, pointRadius: 6, pointHoverRadius: 8 }]
            },
            options: {
                responsive: true, maintainAspectRatio: false,
                plugins: {
                    legend: { display: false },
                    tooltip: { callbacks: { title:(items)=>displayName(names[items[0].dataIndex]), label:(item)=>'  '+perfs[item.dataIndex], afterLabel:(item)=>'  '+labels[item.dataIndex] }, backgroundColor:'#1f2937', borderColor:'#374151', borderWidth:1, titleColor:'#f3f4f6', bodyColor:'#9ca3af' }
                },
                scales: {
                    x: { grid:{color:'rgba(75,85,99,0.3)'}, ticks:{color:'#6b7280',font:{size:11}} },
                    y: { grid:{color:'rgba(75,85,99,0.3)'}, ticks:{color:'#6b7280',font:{size:11},callback:(v)=>isField?fmtInches(v):fmtSecs(v)} }
                }
            }
        });
    }

    // View toggle
    function showView(view) {
        document.querySelectorAll('.view-content').forEach(el => el.classList.add('hidden'));
        document.getElementById(view + '-content').classList.remove('hidden');
        document.querySelectorAll('#all-tab, #prs-tab').forEach(btn => {
            btn.classList.remove('pill-tab-active');
        });
        const tab = document.getElementById(view + '-tab');
        if (tab) tab.classList.add('pill-tab-active');
        applyClassFilter(currentClassFilter);
    }

    // Class filter
    let currentClassFilter = 'all';

    function filterByClass(cls) {
        currentClassFilter = cls;
        document.querySelectorAll('.class-tab').forEach(btn => btn.classList.remove('pill-tab-active'));
        const active = document.getElementById('class-' + cls);
        if (active) active.classList.add('pill-tab-active');
        applyClassFilter(cls);
    }

    function applyClassFilter(cls) {
        const allContainer = document.getElementById('all-content');
        if (allContainer) {
            let visibleRank = 1;
            allContainer.querySelectorAll('tbody tr[data-class]').forEach(function (row) {
                const matches = cls === 'all' || row.dataset.class === cls;
                row.style.display = matches ? '' : 'none';
                if (matches) {
                    const span = row.querySelector('.rank-cell span');
                    if (span) { span.textContent = visibleRank; span.className = 'text-xl font-bold tabular-nums ' + (visibleRank <= 3 ? 'text-amber-400' : 'text-gray-400 dark:text-gray-500'); }
                    visibleRank++;
                }
            });
        }
        const prsContainer = document.getElementById('prs-content');
        if (prsContainer) {
            prsContainer.querySelectorAll('.prs-section').forEach(s => s.classList.add('hidden'));
            const target = prsContainer.querySelector('#prs-section-' + cls);
            if (target) target.classList.remove('hidden');
        }
    }

    // Sortable columns
    (function () {
        var sortState = {};

        function getCellVal(row, col) {
            return row.dataset[col + 'Val'] ?? '';
        }

        document.querySelectorAll('th[data-sort-col]').forEach(function (th) {
            th.addEventListener('click', function () {
                var col    = this.dataset.sortCol;
                var type   = this.dataset.sortType;
                var table  = this.closest('table');
                var tbody  = table.querySelector('tbody');
                var rows   = Array.from(tbody.querySelectorAll('tr'));
                var asc    = sortState[col] !== 'asc';
                sortState[col] = asc ? 'asc' : 'desc';

                // Reset all sort indicators
                table.querySelectorAll('.sort-ind').forEach(s => s.textContent = '↕');
                this.querySelector('.sort-ind').textContent = asc ? '↑' : '↓';

                rows.sort(function (a, b) {
                    var va = getCellVal(a, col);
                    var vb = getCellVal(b, col);
                    if (type === 'num') {
                        var diff = parseFloat(va) - parseFloat(vb);
                        return asc ? diff : -diff;
                    }
                    var cmp = va.localeCompare(vb);
                    return asc ? cmp : -cmp;
                });

                rows.forEach(r => tbody.appendChild(r));
            });
        });
    }());

    document.addEventListener('DOMContentLoaded', function () {
        showView('all');
    });
</script>
