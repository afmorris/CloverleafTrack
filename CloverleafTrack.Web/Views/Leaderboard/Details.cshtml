@using Slugify
@model LeaderboardDetailsViewModel

@{
    ViewBag.Title = $"{Model.EventName} - Leaderboard";
    var genderLabel = Model.Gender == CloverleafTrack.Models.Enums.Gender.Male ? "Boys" : "Girls";
    var environmentLabel = Model.Environment == CloverleafTrack.Models.Enums.Environment.Outdoor ? "Outdoor" : "Indoor";
}

@functions {
    string GetClassYear(int? gradYear)
    {
        if (!gradYear.HasValue) return "";
        
        var currentYear = DateTime.Now.Year;
        var currentMonth = DateTime.Now.Month;
        
        // Adjust current year based on whether we're past graduation (typically June)
        var adjustedCurrentYear = currentMonth >= 6 ? currentYear + 1 : currentYear;
        
        var diff = gradYear.Value - adjustedCurrentYear;
        
        return diff switch
        {
            >= 3 => "Freshman",
            2 => "Sophomore",
            1 => "Junior",
            0 => "Senior",
            _ => $"'{gradYear.Value.ToString().Substring(2)}"
        };
    }

    string[] GetRelayAthletes(string athleteName)
    {
        return athleteName?.Split("|~|") ?? Array.Empty<string>();
    }
}

<style>
    .perf-row {
        transition: all 0.2s ease-in-out;
    }
    .perf-row:hover {
        background: rgba(59, 130, 246, 0.1);
    }

    /* SR History two-column layout */
    .sr-history-grid {
        display: grid;
        grid-template-columns: 2fr 3fr;
    }
    .sr-history-left {
        border-right: 1px solid #e5e7eb;
    }
    .dark .sr-history-left {
        border-right-color: #374151;
    }

    /* Timeline */
    .timeline-track { position: relative; padding-left: 1.5rem; }
    .timeline-track::before { content: ''; position: absolute; left: 7px; top: 12px; bottom: 12px; width: 2px; background: #e5e7eb; }
    .dark .timeline-track::before { background: #374151; }
    .timeline-item { position: relative; padding-bottom: 0.75rem; }
    .timeline-item:last-child { padding-bottom: 0; }
    .timeline-dot { position: absolute; left: -1.5rem; top: 3px; width: 16px; height: 16px; border-radius: 50%; border: 2px solid white; }
    .dark .timeline-dot { border-color: #1f2937; }
    .timeline-dot-current { background: #f59e0b; box-shadow: 0 0 8px rgba(245, 158, 11, 0.5); }
    .timeline-dot-past { background: #9ca3af; }
    .dark .timeline-dot-past { background: #4b5563; }
</style>

<!-- Main Content -->
<div class="max-w-7xl mx-auto px-6">

    <!-- Header -->
    <div class="mb-8">
        <a asp-controller="Leaderboard" asp-action="Index" class="text-gray-600 dark:text-gray-400 text-sm mb-2 inline-block">
            ← Back to Leaderboard
        </a>
        <h1 class="text-4xl font-bold text-gray-900 dark:text-white">
            @if (Model.Environment == CloverleafTrack.Models.Enums.Environment.Indoor)
            {
                <span>Indoor</span>
            }
            else
            {
                <span>Outdoor</span>
            } @Model.EventName
        </h1>
        
        <p class="text-gray-600 dark:text-gray-400 text-lg">
            @genderLabel @environmentLabel All-Time Rankings
        </p>
    </div>

    <!-- School Record History -->
    @if (Model.SchoolRecordProgression.Any())
    {
        var current = Model.SchoolRecordProgression.First();
        var first = Model.SchoolRecordProgression.Last();
        var timesbroken = Model.SchoolRecordProgression.Count - 1;

        <div class="mb-8 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl overflow-hidden">
            <!-- Collapsible header -->
            <button id="sr-history-toggle" onclick="toggleSrHistory()"
                    class="w-full flex items-center justify-between px-6 py-4 text-left hover:bg-gray-50 dark:hover:bg-gray-700/50 transition-colors">
                <div class="flex items-center gap-3">
                    <div class="h-5 w-1 rounded-full bg-gradient-to-b from-amber-500 to-yellow-400"></div>
                    <span class="font-semibold text-gray-900 dark:text-white">School Record History</span>
                    <span class="text-xs font-bold px-2 py-0.5 rounded-full bg-amber-100 dark:bg-amber-900/30 text-amber-700 dark:text-amber-400 border border-amber-200 dark:border-amber-700/50 tracking-wide">SR</span>
                    <span class="text-sm text-gray-500 dark:text-gray-400">
                        — broken @timesbroken time@(timesbroken == 1 ? "" : "s") since @first.MeetDate.Year
                    </span>
                </div>
                <svg id="sr-history-chevron" class="w-5 h-5 text-gray-400 transition-transform duration-200"
                     fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                </svg>
            </button>

            <div id="sr-history-body" class="hidden border-t border-gray-200 dark:border-gray-700">
                <div class="sr-history-grid">

                    <!-- Left: Timeline of record holders -->
                    <div class="sr-history-left px-6 py-5">
                        <p class="text-xs font-bold uppercase tracking-wider text-gray-500 dark:text-gray-400 mb-3">Record Holders</p>
                        <div class="timeline-track">
                            @foreach (var moment in Model.SchoolRecordProgression)
                            {
                                var relayMembers = moment.AthleteName.Contains("|~|")
                                    ? moment.AthleteName.Split("|~|")
                                    : null;
                                <div class="timeline-item">
                                    <div class="timeline-dot @(moment.IsCurrentRecord ? "timeline-dot-current" : "timeline-dot-past")"></div>

                                    <div>
                                        <div class="flex items-baseline gap-2 flex-wrap">
                                            @if (relayMembers != null)
                                            {
                                                <span class="font-semibold text-gray-900 dark:text-gray-200 text-sm">
                                                    @string.Join(" / ", relayMembers)
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="@(moment.IsCurrentRecord ? "font-bold text-gray-900 dark:text-white" : "font-semibold text-gray-700 dark:text-gray-300") text-sm">
                                                    @moment.AthleteName
                                                </span>
                                                @if (moment.GraduationYear.HasValue)
                                                {
                                                    <span class="text-xs text-gray-500">'@(moment.GraduationYear.Value.ToString().Substring(2))</span>
                                                }
                                            }
                                            @if (moment.IsCurrentRecord)
                                            {
                                                <span class="text-xs font-bold px-1.5 py-0.5 rounded bg-amber-100 dark:bg-amber-900/30 text-amber-700 dark:text-amber-400 border border-amber-200 dark:border-amber-700/50">Current SR</span>
                                            }
                                        </div>
                                        <div class="@(moment.IsCurrentRecord ? "text-amber-500 dark:text-amber-400" : "text-gray-700 dark:text-gray-300") font-bold text-base font-mono">
                                            @moment.Performance
                                        </div>
                                        <div class="text-xs text-gray-500">
                                            @moment.MeetDate.ToString("MMM d, yyyy")
                                        </div>
                                        <div class="flex items-center gap-2 mt-1 flex-wrap">
                                            @if (moment.ImprovementFormatted != null)
                                            {
                                                <span class="text-xs font-bold px-1.5 py-0.5 rounded-full bg-green-900/30 text-green-400 border border-green-700/50">
                                                    @moment.ImprovementFormatted
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="text-xs text-gray-600 dark:text-gray-600">First recorded school record</span>
                                            }
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>

                    <!-- Right: Step chart -->
                    <div class="px-6 py-5 flex flex-col">
                        <div class="flex items-center justify-between mb-4">
                            <p class="text-xs font-bold uppercase tracking-wider text-gray-500 dark:text-gray-400">Record Progression</p>
                            <div class="flex items-center gap-2 text-xs text-gray-500">
                                <span class="inline-block w-4 h-0.5 bg-amber-400 rounded"></span>
                                School record at time of performance
                            </div>
                        </div>
                        <div class="flex-1" style="min-height:240px; position:relative;">
                            <canvas id="srProgressionChart"
                                data-labels="@System.Text.Json.JsonSerializer.Serialize(Model.SchoolRecordProgression.OrderBy(p => p.MeetDate).Select(p => p.MeetDate.Year.ToString()).ToList())"
                                data-values="@System.Text.Json.JsonSerializer.Serialize(Model.SchoolRecordProgression.OrderBy(p => p.MeetDate).Select(p => p.RawValue).ToList())"
                                data-names="@System.Text.Json.JsonSerializer.Serialize(Model.SchoolRecordProgression.OrderBy(p => p.MeetDate).Select(p => p.AthleteName).ToList())"
                                data-perfs="@System.Text.Json.JsonSerializer.Serialize(Model.SchoolRecordProgression.OrderBy(p => p.MeetDate).Select(p => p.Performance).ToList())"
                                data-isfield="@Model.IsFieldEvent.ToString().ToLower()">
                            </canvas>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    }

    <!-- View Toggle Tabs -->
    <div class="mb-8 flex gap-3">
        <button onclick="showView('all')" id="all-tab" 
                class="view-tab px-6 py-3 bg-blue-100 dark:bg-blue-500 text-gray-900 dark:text-white rounded-lg border border-blue-300 dark:border-blue-800 font-medium transition-all">
            All Performances (@Model.AllPerformances.Count)
        </button>
        @if (!Model.IsRelayEvent)
        {
            <button onclick="showView('prs')" id="prs-tab"
                    class="view-tab px-6 py-3 bg-gray-100 dark:bg-gray-500 text-gray-900 dark:text-white rounded-lg border border-gray-300 dark:border-gray-800 font-medium transition-all">
                PRs Only (@Model.PersonalRecordsOnly.Count)
            </button>
        }
    </div>

    <!-- All Performances View -->
    <div id="all-content" class="view-content">
        <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl overflow-hidden">
            <div class="overflow-x-auto">
                <table class="min-w-full">
                    <thead class="bg-gray-100 dark:bg-gray-900 border-b">
                        <tr class="text-gray-600 dark:text-gray-400 text-sm">
                            <th class="px-6 py-4 text-left font-semibold">Rank</th>
                            <th class="px-6 py-4 text-left font-semibold">Athlete</th>
                            <th class="px-6 py-4 text-left font-semibold">Class</th>
                            <th class="px-6 py-4 text-left font-semibold">Mark</th>
                            <th class="px-6 py-4 text-left font-semibold">Meet</th>
                            <th class="px-6 py-4 text-left font-semibold">Date</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var perf in Model.AllPerformances)
                        {
                            <tr class="perf-row border-t border-gray-700/50 @(perf.WasRecordAtTime ? "border-l-2 border-l-amber-500 bg-amber-500/5" : "")">
                                <td class="px-6 py-4">
                                    <span class="text-2xl font-bold @(perf.Rank <= 3 ? "text-amber-400" : "text-gray-400")">
                                        @perf.Rank
                                    </span>
                                </td>
                                <td class="px-6 py-4">
                                    @if (perf.AthleteName.Contains("|~|"))
                                    {
                                        var relayMembers = GetRelayAthletes(perf.AthleteName);
                                        <ul class="list-disc list-inside mt-1">
                                            @foreach (var athlete in relayMembers)
                                            {
                                                var split = athlete.Split(' ');
                                                if (split.Length >= 2)
                                                {
                                                    var firstName = split[0];
                                                    var lastName = split[1];
                                                    var helper = new SlugHelper();
                                                    var slug = helper.GenerateSlug($"{firstName}-{lastName}");

                                                    <div class="text-gray-900 dark:text-white">
                                                        <span class="mr-2">•</span>
                                                        <a asp-controller="Roster" asp-action="Details" asp-route-slug="@slug" class="underline">
                                                            @athlete
                                                        </a>
                                                    </div>
                                                }
                                            }
                                        </ul>
                                    }
                                    else
                                    {
                                        @if (!string.IsNullOrEmpty(perf.AthleteSlug))
                                        {
                                            <a asp-controller="Roster" asp-action="Details" asp-route-slug="@perf.AthleteSlug"
                                            class="text-gray-900 dark:text-white font-medium underline">
                                                @perf.AthleteName
                                            </a>
                                        }
                                        else
                                        {
                                            <span class="text-gray-900 dark:text-white font-medium">@perf.AthleteName</span>
                                        }
                                    }
                                </td>
                                <td class="px-6 py-4 text-gray-600 dark:text-gray-400 text-sm">
                                    @GetClassYear(perf.GraduationYear)
                                </td>
                                <td class="px-6 py-4">
                                    <span class="text-xl font-mono font-bold text-gray-900 dark:text-white">
                                        @perf.Performance
                                    </span>
                                    @if (perf.IsSchoolRecord)
                                    {
                                        <span class="ml-2 text-xs font-bold px-1.5 py-0.5 rounded bg-amber-100 dark:bg-amber-900/30 text-amber-700 dark:text-amber-400 border border-amber-200 dark:border-amber-700/50">SR</span>
                                    }
                                    else if (perf.WasRecordAtTime)
                                    {
                                        <span class="ml-2 text-xs font-bold px-1.5 py-0.5 rounded bg-amber-100/50 dark:bg-amber-900/20 text-amber-600 dark:text-amber-500/70 border border-amber-200/50 dark:border-amber-700/30">SR</span>
                                    }
                                </td>
                                <td class="px-6 py-4">
                                    <a asp-controller="Meets" asp-action="Details" asp-route-slug="@perf.MeetSlug"
                                       class="text-gray-600 dark:text-gray-400 underline text-sm">
                                        @perf.MeetName
                                    </a>
                                </td>
                                <td class="px-6 py-4 text-gray-600 dark:text-gray-400 text-sm">
                                    @perf.MeetDate.ToString("MMM d, yyyy")
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        @if (!Model.AllPerformances.Any())
        {
            <div class="p-8 bg-gray-800/50 border border-gray-700 rounded-xl text-center">
                <p class="text-gray-400">No performances recorded for this event yet.</p>
            </div>
        }
    </div>

    <!-- PRs Only View -->
    <div id="prs-content" class="view-content hidden">
        <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl overflow-hidden">
            <div class="overflow-x-auto">
                <table class="min-w-full">
                    <thead class="bg-gray-100 dark:bg-gray-900 border-b">
                        <tr class="text-gray-600 dark:text-gray-400 text-sm">
                            <th class="px-6 py-4 text-left font-semibold">Rank</th>
                            <th class="px-6 py-4 text-left font-semibold">Athlete</th>
                            <th class="px-6 py-4 text-left font-semibold">Class</th>
                            <th class="px-6 py-4 text-left font-semibold">Mark</th>
                            <th class="px-6 py-4 text-left font-semibold">Meet</th>
                            <th class="px-6 py-4 text-left font-semibold">Date</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var perf in Model.PersonalRecordsOnly)
                        {
                            <tr class="perf-row border-t border-gray-700/50 @(perf.WasRecordAtTime ? "border-l-2 border-l-amber-500 bg-amber-500/5" : "")">
                                <td class="px-6 py-4">
                                    <span class="text-2xl font-bold @(perf.Rank <= 3 ? "text-amber-400" : "text-gray-400")">
                                        @perf.Rank
                                    </span>
                                </td>
                                <td class="px-6 py-4">
                                    @if (!string.IsNullOrEmpty(perf.AthleteSlug))
                                    {
                                        <a asp-controller="Roster" asp-action="Details" asp-route-slug="@perf.AthleteSlug"
                                           class="text-gray-900 dark:text-white font-medium underline">
                                            @perf.AthleteName
                                        </a>
                                    }
                                    else
                                    {
                                        <span class="text-gray-900 dark:text-white font-medium">@perf.AthleteName</span>
                                    }
                                </td>
                                <td class="px-6 py-4 text-gray-600 dark:text-gray-400 text-sm">
                                    @GetClassYear(perf.GraduationYear)
                                </td>
                                <td class="px-6 py-4">
                                    <span class="text-xl font-mono font-bold text-gray-900 dark:text-white">
                                        @perf.Performance
                                    </span>
                                </td>
                                <td class="px-6 py-4">
                                    <a asp-controller="Meets" asp-action="Details" asp-route-slug="@perf.MeetSlug"
                                       class="text-gray-600 dark:text-gray-400 underline text-sm">
                                        @perf.MeetName
                                    </a>
                                </td>
                                <td class="px-6 py-4 text-gray-600 dark:text-gray-400 text-sm">
                                    @perf.MeetDate.ToString("MMM d, yyyy")
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
        
        @if (!Model.PersonalRecordsOnly.Any())
        {
            <div class="p-8 bg-gray-800/50 border border-gray-700 rounded-xl text-center">
                <p class="text-gray-400">No personal records for this event yet.</p>
            </div>
        }
    </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script>
    // SR History panel toggle — lazy-initializes chart on first open
    let srChartBuilt = false;
    function toggleSrHistory() {
        const body = document.getElementById('sr-history-body');
        const chevron = document.getElementById('sr-history-chevron');
        const isHidden = body.classList.contains('hidden');
        body.classList.toggle('hidden');
        chevron.style.transform = isHidden ? 'rotate(180deg)' : '';
        if (isHidden && !srChartBuilt) buildSrChart();
    }

    function buildSrChart() {
        srChartBuilt = true;
        const canvas = document.getElementById('srProgressionChart');
        if (!canvas) return;

        const labels  = JSON.parse(canvas.dataset.labels);
        const values  = JSON.parse(canvas.dataset.values);
        const names   = JSON.parse(canvas.dataset.names);
        const perfs   = JSON.parse(canvas.dataset.perfs);
        const isField = canvas.dataset.isfield === 'true';

        // Format raw value (inches or seconds) to a readable string for Y-axis ticks
        function fmtInches(v) {
            const ft = Math.floor(v / 12);
            const rem = v % 12;
            const inchStr = rem === 0 ? '0' : rem.toFixed(2).replace(/\.?0+$/, '');
            return `${ft}' ${inchStr}"`;
        }
        function fmtSeconds(v) {
            if (v >= 60) {
                const m = Math.floor(v / 60);
                const s = v % 60;
                return `${m}:${s.toFixed(2).padStart(5, '0')}`;
            }
            return `${v.toFixed(2)}`;
        }
        function fmtTick(v) { return isField ? fmtInches(v) : fmtSeconds(v); }

        // Relay names are |~|-separated — flatten to a readable string for tooltips
        function displayName(raw) {
            return raw.includes('|~|') ? raw.split('|~|').join(' / ') : raw;
        }

        new Chart(canvas, {
            type: 'line',
            data: {
                labels,
                datasets: [{
                    data: values,
                    borderColor: '#f59e0b',
                    backgroundColor: 'rgba(245,158,11,0.07)',
                    borderWidth: 2.5,
                    stepped: 'before',
                    fill: true,
                    pointBackgroundColor: values.map((_, i) => i === values.length - 1 ? '#f59e0b' : '#4b5563'),
                    pointBorderColor: values.map((_, i) => i === values.length - 1 ? '#1f2937' : '#f59e0b'),
                    pointBorderWidth: 2,
                    pointRadius: 6,
                    pointHoverRadius: 8,
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { display: false },
                    tooltip: {
                        callbacks: {
                            title: (items) => displayName(names[items[0].dataIndex]),
                            label: (item) => '  ' + perfs[item.dataIndex],
                            afterLabel: (item) => '  ' + labels[item.dataIndex],
                        },
                        backgroundColor: '#1f2937',
                        borderColor: '#374151',
                        borderWidth: 1,
                        titleColor: '#f3f4f6',
                        bodyColor: '#9ca3af',
                    }
                },
                scales: {
                    x: {
                        grid: { color: 'rgba(75,85,99,0.3)' },
                        ticks: { color: '#6b7280', font: { size: 11 } },
                    },
                    y: {
                        grid: { color: 'rgba(75,85,99,0.3)' },
                        ticks: {
                            color: '#6b7280',
                            font: { size: 11 },
                            callback: (v) => fmtTick(v),
                        },
                    }
                }
            }
        });
    }

    function showView(view) {
        // Hide all content
        document.querySelectorAll('.view-content').forEach(el => el.classList.add('hidden'));
        
        // Show selected content
        document.getElementById(view + '-content').classList.remove('hidden');
        
        // Update tab styling
        document.querySelectorAll('.view-tab').forEach(tab => {
            tab.classList.remove('bg-blue-100', 'dark:bg-blue-500', 'border-blue-300', 'dark:border-blue-800');
            tab.classList.add('bg-gray-100', 'dark:bg-gray-500', 'border-gray-300', 'dark:border-gray-800');
        });
        
        const activeTab = document.getElementById(view + '-tab');
        activeTab.classList.remove('bg-gray-100', 'dark:bg-gray-500', 'border-gray-300', 'dark:border-gray-800');
        activeTab.classList.add('bg-blue-100', 'dark:bg-blue-500', 'border-blue-300', 'dark:border-blue-800');
    }
    
    // Set "all" as default on page load
    document.addEventListener('DOMContentLoaded', function() {
        showView('all');
    });
</script>
