@using Slugify
@model AthleteDetailsViewModel

@{
    ViewBag.Title = Model.FullName;
    var individualRecords = Model.PersonalRecords.Where(pr => !pr.IsRelay).ToList();
    var relayRecords = Model.PersonalRecords.Where(pr => pr.IsRelay).ToList();
    var hasAnyIndividualRank = individualRecords.Any(pr => pr.AllTimeRank.HasValue || pr.IsSchoolRecord);
    var hasAnyRelayRank = relayRecords.Any(pr => pr.AllTimeRank.HasValue || pr.IsSchoolRecord);
}

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

    <!-- Hero -->
    <div class="mb-8">
        <div class="mb-3">
            <h1 class="text-3xl font-bold text-gray-900 dark:text-white">@Model.FullName</h1>
            <p class="text-gray-500 dark:text-gray-400 mt-1 text-sm">@Model.Class · @(Model.Gender == Gender.Male ? "Boys" : "Girls")</p>
        </div>
        <div class="bg-white dark:bg-gray-800 rounded-lg border border-gray-200 dark:border-gray-700 overflow-hidden">
            <div class="metric-strip">
                @if (Model.TopSprintEvent != null)
                {
                    <div class="metric-cell">
                        <span class="metric-value mark">@Model.TopSprintEvent.Performance</span>
                        <span class="metric-label">@Model.TopSprintEvent.EventName</span>
                        @if (Model.TopSprintEvent.AllTimeRank == 1)
                        {
                            <span class="chip-sr mt-1">SR</span>
                        }
                        else if (Model.TopSprintEvent.AllTimeRank.HasValue)
                        {
                            <span class="chip-rank mt-1">#@Model.TopSprintEvent.AllTimeRank</span>
                        }
                    </div>
                }
                @if (Model.TopFieldEvent != null)
                {
                    <div class="metric-cell">
                        <span class="metric-value mark">@Model.TopFieldEvent.Performance</span>
                        <span class="metric-label">@Model.TopFieldEvent.EventName</span>
                        @if (Model.TopFieldEvent.AllTimeRank == 1)
                        {
                            <span class="chip-sr mt-1">SR</span>
                        }
                        else if (Model.TopFieldEvent.AllTimeRank.HasValue)
                        {
                            <span class="chip-rank mt-1">#@Model.TopFieldEvent.AllTimeRank</span>
                        }
                    </div>
                }
                <div class="metric-cell">
                    <span class="metric-value text-pr">@Model.TotalPRs</span>
                    <span class="metric-label">PRs</span>
                </div>
                <div class="metric-cell">
                    <span class="metric-value text-sr">@Model.TotalSchoolRecords</span>
                    <span class="metric-label">Records</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Personal Bests -->
    @if (Model.PersonalRecords.Any())
    {
        <section class="mb-8">
            <h2 class="text-xl font-bold mb-3 text-gray-900 dark:text-white">Personal Bests</h2>
            <div class="bg-white dark:bg-gray-800 rounded-lg border border-gray-200 dark:border-gray-700 overflow-hidden">
                @foreach (var env in new[] { CloverleafTrack.Models.Enums.Environment.Outdoor, CloverleafTrack.Models.Enums.Environment.Indoor })
                {
                    var indivRecs = individualRecords.Where(x => x.Environment == env).ToList();
                    var relRecs   = relayRecords.Where(x => x.Environment == env).ToList();
                    if (!indivRecs.Any() && !relRecs.Any()) continue;

                    var isOutdoor = env == CloverleafTrack.Models.Enums.Environment.Outdoor;
                    var hdrClass   = isOutdoor
                        ? "bg-amber-50 dark:bg-amber-900/20 border-b border-amber-200 dark:border-amber-700/30"
                        : "bg-blue-50 dark:bg-blue-900/20 border-b border-blue-200 dark:border-blue-700/30";
                    var hdrText    = isOutdoor
                        ? "text-amber-800 dark:text-amber-400"
                        : "text-blue-700 dark:text-blue-400";

                    <div class="@hdrClass px-4 py-2.5 border-t border-gray-100 dark:border-gray-700 first:border-t-0">
                        <h3 class="text-xs font-semibold uppercase tracking-wide @hdrText">@(isOutdoor ? "Outdoor" : "Indoor")</h3>
                    </div>

                    @if (indivRecs.Any())
                    {
                        <table class="w-full text-sm">
                            <thead>
                                <tr class="bg-gray-50 dark:bg-gray-700/50 text-xs uppercase tracking-wide text-gray-500 dark:text-gray-400">
                                    <th class="px-4 py-2 text-left font-medium">Event</th>
                                    <th class="px-4 py-2 text-left font-medium">Best</th>
                                    <th class="px-4 py-2 text-left font-medium hidden sm:table-cell">Date</th>
                                    <th class="px-4 py-2 text-left font-medium hidden md:table-cell">Meet</th>
                                    @if (hasAnyIndividualRank)
                                    {
                                        <th class="px-4 py-2 text-left font-medium w-px"></th>
                                    }
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-gray-100 dark:divide-gray-700">
                                @foreach (var pr in indivRecs)
                                {
                                    var rowClass = pr.IsSchoolRecord ? "row-sr" : "";
                                    <tr class="hover:bg-gray-50 dark:hover:bg-gray-700/50 @rowClass">
                                        <td class="px-4 py-2.5 font-medium text-gray-900 dark:text-gray-100">@pr.EventName</td>
                                        <td class="px-4 py-2.5"><span class="mark font-bold text-gray-900 dark:text-gray-100">@pr.Performance</span></td>
                                        <td class="px-4 py-2.5 text-gray-500 dark:text-gray-400 hidden sm:table-cell">@pr.Date.ToString("MMM d, yyyy")</td>
                                        <td class="px-4 py-2.5 text-gray-700 dark:text-gray-300 hidden md:table-cell">
                                            @{ var helper = new SlugHelper(); var meetSlug = helper.GenerateSlug(pr.MeetName); }
                                            <a asp-controller="Meets" asp-action="Details" asp-route-slug="@meetSlug" class="underline hover:text-ctf-darkaccent dark:hover:text-ctf-accent">@pr.MeetName</a>
                                        </td>
                                        @if (hasAnyIndividualRank)
                                        {
                                            <td class="px-4 py-2.5">
                                                <div class="flex gap-1 flex-wrap items-center">
                                                    @if (pr.IsSchoolRecord) { <span class="chip-sr">SR</span> }
                                                    @if (pr.AllTimeRank.HasValue) { <span class="chip-rank">#@pr.AllTimeRank AT</span> }
                                                </div>
                                            </td>
                                        }
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }

                    @if (relRecs.Any())
                    {
                        <div class="px-4 py-2 bg-gray-50 dark:bg-gray-700/30 border-t border-gray-100 dark:border-gray-700 text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wide">Relays</div>
                        <table class="w-full text-sm">
                            <thead>
                                <tr class="bg-gray-50 dark:bg-gray-700/50 text-xs uppercase tracking-wide text-gray-500 dark:text-gray-400">
                                    <th class="px-4 py-2 text-left font-medium">Event</th>
                                    <th class="px-4 py-2 text-left font-medium">Best</th>
                                    <th class="px-4 py-2 text-left font-medium hidden sm:table-cell">Date</th>
                                    <th class="px-4 py-2 text-left font-medium hidden md:table-cell">Meet</th>
                                    @if (hasAnyRelayRank)
                                    {
                                        <th class="px-4 py-2 text-left font-medium w-px"></th>
                                    }
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-gray-100 dark:divide-gray-700">
                                @foreach (var pr in relRecs)
                                {
                                    var rowClass = pr.IsSchoolRecord ? "row-sr" : "";
                                    <tr class="hover:bg-gray-50 dark:hover:bg-gray-700/50 @rowClass">
                                        <td class="px-4 py-2.5">
                                            <div class="font-medium text-gray-900 dark:text-gray-100">@pr.EventName</div>
                                            <div class="text-xs text-gray-500 dark:text-gray-400 mt-0.5">
                                                @for (int mi = 0; mi < pr.RelayMembers.Length; mi++)
                                                {
                                                    var member = pr.RelayMembers[mi];
                                                    var parts = member.Trim().Split(' ');
                                                    var mSlug = parts.Length >= 2
                                                        ? new SlugHelper().GenerateSlug($"{parts[0]}-{parts[1]}")
                                                        : new SlugHelper().GenerateSlug(member);
                                                    <a asp-controller="Roster" asp-action="Details" asp-route-slug="@mSlug" class="underline hover:text-gray-700 dark:hover:text-gray-200">@member</a>@if (mi < pr.RelayMembers.Length - 1) { <span> / </span> }
                                                }
                                            </div>
                                        </td>
                                        <td class="px-4 py-2.5"><span class="mark font-bold text-gray-900 dark:text-gray-100">@pr.Performance</span></td>
                                        <td class="px-4 py-2.5 text-gray-500 dark:text-gray-400 hidden sm:table-cell">@pr.Date.ToString("MMM d, yyyy")</td>
                                        <td class="px-4 py-2.5 text-gray-700 dark:text-gray-300 hidden md:table-cell">
                                            @{ var helper2 = new SlugHelper(); var mSlug2 = helper2.GenerateSlug(pr.MeetName); }
                                            <a asp-controller="Meets" asp-action="Details" asp-route-slug="@mSlug2" class="underline hover:text-ctf-darkaccent dark:hover:text-ctf-accent">@pr.MeetName</a>
                                        </td>
                                        @if (hasAnyRelayRank)
                                        {
                                            <td class="px-4 py-2.5">
                                                <div class="flex gap-1 flex-wrap items-center">
                                                    @if (pr.IsSchoolRecord) { <span class="chip-sr">SR</span> }
                                                    @if (pr.AllTimeRank.HasValue) { <span class="chip-rank">#@pr.AllTimeRank AT</span> }
                                                </div>
                                            </td>
                                        }
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                }
            </div>
        </section>
    }
    else
    {
        <section class="mb-8">
            <h2 class="text-xl font-bold mb-3 text-gray-900 dark:text-white">Personal Bests</h2>
            <div class="bg-white dark:bg-gray-800 rounded-lg border border-gray-200 dark:border-gray-700 p-12 text-center">
                <svg class="w-16 h-16 mx-auto mb-4 text-gray-300 dark:text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"></path>
                </svg>
                <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-2">No Performances Yet</h3>
                <p class="text-sm text-gray-600 dark:text-gray-400">Check back after this athlete competes in their first meet.</p>
            </div>
        </section>
    }

    <!-- Performance by Season -->
    @if (Model.Seasons.Any())
    {
        <section class="mb-8">
            <h2 class="text-xl font-bold mb-3 text-gray-900 dark:text-white">Performance by Season</h2>

            <!-- Season pill tabs -->
            <div class="flex flex-wrap gap-2 mb-4" role="tablist" aria-label="Season selector">
                @for (int si = 0; si < Model.Seasons.Count; si++)
                {
                    var s = Model.Seasons[si];
                    <button type="button"
                            class="pill-tab @(si == 0 ? "pill-tab-active" : "")"
                            role="tab"
                            aria-selected="@(si == 0 ? "true" : "false")"
                            aria-controls="season-panel-@si"
                            data-season-target="season-panel-@si">
                        @s.SeasonName
                        @if (s.PRCount > 0)
                        {
                            <span class="ml-1 opacity-70">@s.PRCount PR@(s.PRCount != 1 ? "s" : "")</span>
                        }
                    </button>
                }
            </div>

            <!-- Season panels -->
            @{ bool firstEventRendered = false; }
            @for (int si = 0; si < Model.Seasons.Count; si++)
            {
                var season = Model.Seasons[si];
                <div id="season-panel-@si" class="season-panel @(si == 0 ? "" : "hidden")" role="tabpanel" aria-labelledby="">
                    @foreach (var env in new[] { CloverleafTrack.Models.Enums.Environment.Outdoor, CloverleafTrack.Models.Enums.Environment.Indoor })
                    {
                        var envGroups = season.EventGroups.Where(x => x.Environment == env).ToList();
                        if (!envGroups.Any()) continue;

                        var isOutdoor = env == CloverleafTrack.Models.Enums.Environment.Outdoor;
                        var envLabel = isOutdoor ? "Outdoor" : "Indoor";
                        var envHeadClass = isOutdoor
                            ? "text-amber-700 dark:text-amber-400"
                            : "text-blue-700 dark:text-blue-400";
                        var summaryBg = isOutdoor
                            ? "bg-amber-50 dark:bg-amber-900/10 border-b border-amber-100 dark:border-amber-900/20 hover:bg-amber-100 dark:hover:bg-amber-900/20"
                            : "bg-blue-50 dark:bg-blue-900/10 border-b border-blue-100 dark:border-blue-900/20 hover:bg-blue-100 dark:hover:bg-blue-900/20";
                        var summaryText = isOutdoor
                            ? "text-amber-900 dark:text-amber-300"
                            : "text-blue-900 dark:text-blue-300";
                        var arrowColor = isOutdoor
                            ? "text-amber-400 dark:text-amber-600"
                            : "text-blue-400 dark:text-blue-600";

                        <h3 class="text-xs font-semibold uppercase tracking-wide mb-2 mt-4 first:mt-0 @envHeadClass">@envLabel</h3>

                        @foreach (var eg in envGroups)
                        {
                            var openAttr = !firstEventRendered ? "open" : "";
                            firstEventRendered = true;
                            <details @openAttr class="mb-2 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg overflow-hidden">
                                <summary class="px-4 py-2.5 @summaryBg cursor-pointer list-none flex items-center justify-between select-none transition-colors">
                                    <div class="flex items-center gap-2 flex-wrap">
                                        <span class="font-medium @summaryText text-sm">@eg.EventName</span>
                                        @if (!string.IsNullOrEmpty(eg.PersonalRecordPerformance))
                                        {
                                            <span class="mark text-sm @summaryText">@eg.PersonalRecordPerformance</span>
                                            @if (eg.Performances.Any(p => p.IsPersonalBest))
                                            {
                                                <span class="chip-pr">PR</span>
                                            }
                                            @if (eg.Performances.Any(p => p.IsSchoolRecord))
                                            {
                                                <span class="chip-sr">SR</span>
                                            }
                                        }
                                    </div>
                                    <svg class="details-arrow w-4 h-4 @arrowColor flex-shrink-0 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                                    </svg>
                                </summary>

                                <table class="w-full text-sm">
                                    <thead>
                                        <tr class="bg-gray-50 dark:bg-gray-700/50 text-xs uppercase tracking-wide text-gray-500 dark:text-gray-400">
                                            <th class="px-4 py-2 text-left font-medium">Mark</th>
                                            <th class="px-4 py-2 text-left font-medium hidden sm:table-cell">Date</th>
                                            <th class="px-4 py-2 text-left font-medium">Meet</th>
                                            <th class="px-4 py-2 text-right font-medium">Δ</th>
                                        </tr>
                                    </thead>
                                    <tbody class="divide-y divide-gray-100 dark:divide-gray-700">
                                        @foreach (var perf in eg.Performances)
                                        {
                                            double? gap = null;
                                            if (eg.PersonalRecordRawValue.HasValue && perf.RawValue.HasValue)
                                            {
                                                gap = eg.IsFieldEvent
                                                    ? eg.PersonalRecordRawValue.Value - perf.RawValue.Value
                                                    : perf.RawValue.Value - eg.PersonalRecordRawValue.Value;
                                            }
                                            var tRowClass = perf.IsSchoolRecord ? "row-sr" : (perf.IsPersonalBest ? "row-pr" : "");

                                            <tr class="hover:bg-gray-50 dark:hover:bg-gray-700/50 @tRowClass">
                                                <td class="px-4 py-2.5">
                                                    <div class="flex items-center gap-1.5 flex-wrap">
                                                        <span class="mark font-bold text-gray-900 dark:text-gray-100">@perf.Performance</span>
                                                        @if (perf.IsSchoolRecord) { <span class="chip-sr">SR</span> }
                                                        @if (perf.IsPersonalBest) { <span class="chip-pr">PR</span> }
                                                        @if (perf.AllTimeRank.HasValue && perf.AllTimeRank <= 10)
                                                        {
                                                            <span class="chip-rank">#@perf.AllTimeRank</span>
                                                        }
                                                    </div>
                                                    @if (perf.IsRelay)
                                                    {
                                                        <div class="text-xs text-gray-500 dark:text-gray-400 mt-0.5">
                                                            @for (int mi = 0; mi < perf.RelayMembers.Length; mi++)
                                                            {
                                                                var member = perf.RelayMembers[mi];
                                                                var parts = member.Trim().Split(' ');
                                                                var rmSlug = parts.Length >= 2
                                                                    ? new SlugHelper().GenerateSlug($"{parts[0]}-{parts[1]}")
                                                                    : new SlugHelper().GenerateSlug(member);
                                                                <a asp-controller="Roster" asp-action="Details" asp-route-slug="@rmSlug" class="underline hover:text-gray-700 dark:hover:text-gray-200">@member</a>@if (mi < perf.RelayMembers.Length - 1) { <span> / </span> }
                                                            }
                                                        </div>
                                                    }
                                                </td>
                                                <td class="px-4 py-2.5 text-gray-500 dark:text-gray-400 hidden sm:table-cell">@perf.Date.ToString("MMM d")</td>
                                                <td class="px-4 py-2.5 text-gray-700 dark:text-gray-300">
                                                    @{ var h = new SlugHelper(); var ms = h.GenerateSlug(perf.MeetName); }
                                                    <a asp-controller="Meets" asp-action="Details" asp-route-slug="@ms" class="underline hover:text-ctf-darkaccent dark:hover:text-ctf-accent block truncate max-w-[200px]">@perf.MeetName</a>
                                                </td>
                                                <td class="px-4 py-2.5 text-right tabular-nums">
                                                    @if (gap.HasValue && gap.Value > 0.001)
                                                    {
                                                        <span class="text-xs text-gray-400 dark:text-gray-500">+@FormatImprovement(gap.Value, eg.IsFieldEvent)</span>
                                                    }
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </details>
                        }
                    }
                </div>
            }
        </section>
    }

</div>

@functions {
    static string FormatImprovement(double delta, bool isField)
    {
        if (isField)
        {
            int totalInches = (int)Math.Round(delta);
            int feet = totalInches / 12;
            int inches = totalInches % 12;
            return feet > 0 ? $"{feet}' {inches}\"" : $"{inches}\"";
        }
        if (delta >= 60)
        {
            int mins = (int)(delta / 60);
            double secs = delta % 60;
            return $"{mins}:{secs:00.00}";
        }
        return delta.ToString("0.00") + "s";
    }
}

@section Scripts {
<script>
    document.addEventListener('DOMContentLoaded', function () {
        document.querySelectorAll('[data-season-target]').forEach(btn => {
            btn.addEventListener('click', function () {
                const targetId = this.dataset.seasonTarget;
                document.querySelectorAll('[data-season-target]').forEach(b => {
                    b.classList.remove('pill-tab-active');
                    b.setAttribute('aria-selected', 'false');
                });
                this.classList.add('pill-tab-active');
                this.setAttribute('aria-selected', 'true');
                document.querySelectorAll('.season-panel').forEach(p => p.classList.add('hidden'));
                const panel = document.getElementById(targetId);
                if (panel) panel.classList.remove('hidden');
            });
        });
    });
</script>
}
