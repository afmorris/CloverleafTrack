@using Slugify
@model AthleteDetailsViewModel

@{
    ViewBag.Title = Model.FullName;
    var hasAnyRank = Model.PersonalRecords.Any(pr => pr.AllTimeRank.HasValue || pr.IsSchoolRecord);

    var careerEvents = Model.Seasons
        .SelectMany(s => s.EventGroups)
        .Where(eg => eg.Performances.Any(p => !p.IsRelay))
        .GroupBy(eg => new { eg.EventId, eg.EventName, eg.IsFieldEvent, eg.Environment })
        .Select(g => new
        {
            EventId     = g.Key.EventId,
            EventName   = g.Key.EventName,
            IsField     = g.Key.IsFieldEvent,
            Environment = g.Key.Environment,
            Perfs       = g.SelectMany(eg => eg.Performances)
                           .Where(p => !p.IsRelay && p.RawValue.HasValue)
                           .OrderBy(p => p.Date)
                           .ToList()
        })
        .Where(g => g.Perfs.Count > 1)
        .ToList();
}

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

    <!-- Hero Section -->
    <div class="mb-8 bg-white dark:bg-gray-800 rounded-lg border border-gray-200 dark:border-gray-700 p-6">
        <h1 class="text-4xl font-bold mb-2 text-gray-900 dark:text-white">@Model.FullName</h1>
        <div class="text-lg text-gray-600 dark:text-gray-400 mb-6">
            @Model.Class • @(Model.Gender == Gender.Male ? "Boys" : "Girls")
        </div>

        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
            @if (Model.TopSprintEvent != null)
            {
                <div class="border-l-4 border-l-blue-500 pl-4">
                    <div class="text-3xl font-bold text-blue-600 dark:text-blue-400">@Model.TopSprintEvent.Performance</div>
                    <div class="text-sm text-gray-600 dark:text-gray-400">@Model.TopSprintEvent.EventName PR</div>
                    <div class="text-xs text-gray-500 dark:text-gray-500">
                        @if (Model.TopSprintEvent.Environment == CloverleafTrack.Models.Enums.Environment.Indoor)
                        { <span aria-label="Indoor">🏢 Indoor</span> }
                        else
                        { <span aria-label="Outdoor">☀️ Outdoor</span> }
                    </div>
                    @if (Model.TopSprintEvent.AllTimeRank.HasValue)
                    {
                        <div class="text-xs text-gray-500 dark:text-gray-500">#@Model.TopSprintEvent.AllTimeRank All-Time</div>
                    }
                </div>
            }

            @if (Model.TopFieldEvent != null)
            {
                <div class="border-l-4 border-l-green-500 pl-4">
                    <div class="text-3xl font-bold text-green-600 dark:text-green-400">@Model.TopFieldEvent.Performance</div>
                    <div class="text-sm text-gray-600 dark:text-gray-400">@Model.TopFieldEvent.EventName PR</div>
                    <div class="text-xs text-gray-500 dark:text-gray-500">
                        @if (Model.TopFieldEvent.Environment == CloverleafTrack.Models.Enums.Environment.Indoor)
                        { <span aria-label="Indoor">🏢 Indoor</span> }
                        else
                        { <span aria-label="Outdoor">☀️ Outdoor</span> }
                    </div>
                    @if (Model.TopFieldEvent.AllTimeRank.HasValue)
                    {
                        <div class="text-xs text-gray-500 dark:text-gray-500">#@Model.TopFieldEvent.AllTimeRank All-Time</div>
                    }
                </div>
            }

            <div class="border-l-4 border-l-purple-500 pl-4">
                <div class="text-3xl font-bold text-purple-600 dark:text-purple-400">@Model.TotalPRs</div>
                <div class="text-sm text-gray-600 dark:text-gray-400">Total PRs</div>
            </div>

            <div class="border-l-4 border-l-yellow-500 pl-4">
                <div class="text-3xl font-bold text-yellow-600 dark:text-yellow-400">@Model.TotalSchoolRecords</div>
                <div class="text-sm text-gray-600 dark:text-gray-400">School Records</div>
            </div>
        </div>
    </div>

    <!-- Career Progression (stats summary, no charts) -->
    @if (careerEvents.Any())
    {
        <div class="mb-8">
            <h2 class="text-2xl font-bold mb-4 text-gray-900 dark:text-white">Career Progression</h2>

            <div class="bg-white dark:bg-gray-800 rounded-lg border border-gray-200 dark:border-gray-700 overflow-hidden">

                <div class="flex flex-wrap gap-2 p-4 border-b border-gray-200 dark:border-gray-700" role="tablist" aria-label="Career events">
                    @for (int ci = 0; ci < careerEvents.Count; ci++)
                    {
                        var ce = careerEvents[ci];
                        var isFirst = ci == 0;
                        var ceIsOutdoor = ce.Environment == CloverleafTrack.Models.Enums.Environment.Outdoor;
                        var activeClass = ceIsOutdoor
                            ? "bg-amber-500 text-white border-amber-600 shadow-md ring-2 ring-amber-400/50"
                            : "bg-blue-600 text-white border-blue-700 shadow-md ring-2 ring-blue-400/50";
                        <button type="button"
                                role="tab"
                                aria-selected="@(isFirst ? "true" : "false")"
                                aria-controls="career-panel-@ci"
                                class="career-tab px-3 py-1.5 rounded-full text-sm font-semibold border transition-all @(isFirst ? activeClass : "border-gray-300 dark:border-gray-600 text-gray-600 dark:text-gray-300 hover:border-gray-400 dark:hover:border-gray-500")"
                                data-target="career-panel-@ci"
                                data-active-class="@activeClass">
                            <span aria-hidden="true">@(ceIsOutdoor ? "☀️" : "🏢")</span>
                            @ce.EventName
                        </button>
                    }
                </div>

                @for (int ci = 0; ci < careerEvents.Count; ci++)
                {
                    var ce = careerEvents[ci];
                    var isFirst = ci == 0;
                    var cePerfs = ce.Perfs;

                    var totalComps = cePerfs.Count;
                    var firstPerf  = cePerfs.First();
                    var bestPerf   = ce.IsField
                        ? cePerfs.OrderByDescending(p => p.RawValue).First()
                        : cePerfs.OrderBy(p => p.RawValue).First();
                    var bestRank   = cePerfs.Where(p => p.AllTimeRank.HasValue).OrderBy(p => p.AllTimeRank).FirstOrDefault();

                    double delta  = bestPerf.RawValue!.Value - firstPerf.RawValue!.Value;
                    bool improved = ce.IsField ? delta > 0 : delta < 0;
                    var improvStr = delta != 0
                        ? $"{(delta > 0 ? "+" : "-")}{FormatImprovement(Math.Abs(delta), ce.IsField)}"
                        : "—";

                    <div id="career-panel-@ci" class="career-panel @(isFirst ? "" : "hidden") p-5" role="tabpanel">
                        @{
                            var panelIsOutdoor = ce.Environment == CloverleafTrack.Models.Enums.Environment.Outdoor;
                        }
                        <div class="flex items-center gap-2 mb-3">
                            <h3 class="font-semibold text-gray-900 dark:text-white">@ce.EventName</h3>
                            <span class="px-2 py-0.5 text-xs font-semibold rounded @(panelIsOutdoor ? "bg-amber-50 dark:bg-amber-900/20 text-amber-700 dark:text-amber-400 border border-amber-200 dark:border-amber-700/30" : "bg-blue-50 dark:bg-blue-900/20 text-blue-700 dark:text-blue-400 border border-blue-200 dark:border-blue-700/30")">
                                @(panelIsOutdoor ? "☀️ Outdoor" : "🏢 Indoor")
                            </span>
                        </div>
                        <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
                            <div class="bg-gray-50 dark:bg-gray-700 rounded-lg p-3">
                                <div class="text-xs text-gray-500 dark:text-gray-400 mb-0.5">Career PR</div>
                                <div class="font-bold text-gray-900 dark:text-white">@bestPerf.Performance</div>
                                <div class="text-xs text-gray-500 dark:text-gray-400">@bestPerf.Date.ToString("MMM d, yyyy")</div>
                            </div>
                            <div class="bg-gray-50 dark:bg-gray-700 rounded-lg p-3">
                                <div class="text-xs text-gray-500 dark:text-gray-400 mb-0.5">Competitions</div>
                                <div class="font-bold text-gray-900 dark:text-white">@totalComps</div>
                                <div class="text-xs text-gray-500 dark:text-gray-400">@Model.Seasons.Count(s => s.EventGroups.Any(eg => eg.EventName == ce.EventName)) season(s)</div>
                            </div>
                            <div class="bg-gray-50 dark:bg-gray-700 rounded-lg p-3">
                                <div class="text-xs text-gray-500 dark:text-gray-400 mb-0.5">Career improvement</div>
                                <div class="font-bold @(improved ? "text-green-600 dark:text-green-400" : "text-gray-900 dark:text-white")">@improvStr</div>
                                <div class="text-xs text-gray-500 dark:text-gray-400">first → best</div>
                            </div>
                            <div class="bg-gray-50 dark:bg-gray-700 rounded-lg p-3">
                                <div class="text-xs text-gray-500 dark:text-gray-400 mb-0.5">All-time rank</div>
                                @if (bestRank != null)
                                {
                                    <div class="font-bold text-purple-600 dark:text-purple-400">#@bestRank.AllTimeRank</div>
                                    <div class="text-xs text-gray-500 dark:text-gray-400">@bestRank.Performance · @bestRank.Date.ToString("MMM d, yyyy")</div>
                                }
                                else
                                {
                                    <div class="font-bold text-gray-400">—</div>
                                    <div class="text-xs text-gray-500 dark:text-gray-400">unranked</div>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    }

    <!-- Personal Records Table -->
    @if (Model.PersonalRecords.Any())
    {
        <div class="mb-8">
            <h2 class="text-2xl font-bold mb-4 text-gray-900 dark:text-white">Personal Records</h2>
            <div class="bg-white dark:bg-gray-800 rounded-lg border border-gray-200 dark:border-gray-700 overflow-hidden">

                @if (Model.PersonalRecords.Where(x => x.Environment == CloverleafTrack.Models.Enums.Environment.Outdoor).Any())
                {
                    <div class="bg-amber-50 dark:bg-yellow-900/20 border-b border-yellow-200 dark:border-yellow-800/30 px-6 py-3">
                        <div class="flex items-center gap-3">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-amber-600 dark:text-yellow-500" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                                <path fill-rule="evenodd" d="M12 2.25a.75.75 0 01.75.75v1.5a.75.75 0 01-1.5 0V3A.75.75 0 0112 2.25zM17.47 4.53a.75.75 0 011.06 1.06l-1.06 1.06a.75.75 0 11-1.06-1.06l1.06-1.06zM21.75 12a.75.75 0 01-.75.75h-1.5a.75.75 0 010-1.5H21a.75.75 0 01.75.75zM17.47 19.47a.75.75 0 00-1.06-1.06l-1.06 1.06a.75.75 0 001.06 1.06l1.06-1.06zM12 20.25a.75.75 0 01-.75-.75v-1.5a.75.75 0 011.5 0v1.5a.75.75 0 01-.75.75zM6.53 19.47a.75.75 0 001.06-1.06L6.53 17.35a.75.75 0 00-1.06 1.06l1.06 1.06zM2.25 12a.75.75 0 01.75-.75h1.5a.75.75 0 010 1.5H3a.75.75 0 01-.75-.75zM6.53 4.53a.75.75 0 00-1.06 1.06L6.53 6.65a.75.75 0 001.06-1.06L6.53 4.53zM12 6.75a5.25 5.25 0 100 10.5 5.25 5.25 0 000-10.5z" clip-rule="evenodd" />
                            </svg>
                            <h3 class="font-bold text-lg text-amber-800 dark:text-yellow-400 uppercase tracking-wider">Outdoor</h3>
                        </div>
                    </div>

                    <table class="min-w-full">
                        <thead class="bg-gray-100 dark:bg-gray-700">
                            <tr>
                                <th class="px-4 py-3 text-left text-sm font-semibold text-gray-900 dark:text-white">Event</th>
                                <th class="px-4 py-3 text-left text-sm font-semibold text-gray-900 dark:text-white">PR</th>
                                <th class="px-4 py-3 text-left text-sm font-semibold text-gray-900 dark:text-white">Date</th>
                                <th class="px-4 py-3 text-left text-sm font-semibold text-gray-900 dark:text-white">Meet</th>
                                @if (hasAnyRank)
                                {
                                    <th class="px-4 py-3 text-center text-sm font-semibold text-gray-900 dark:text-white">Rank</th>
                                }
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-200 dark:divide-gray-700">
                            @foreach (var pr in Model.PersonalRecords.Where(x => x.Environment == CloverleafTrack.Models.Enums.Environment.Outdoor))
                            {
                                <tr class="hover:bg-gray-200 dark:hover:bg-gray-600">
                                    <td class="px-4 py-3 text-gray-900 dark:text-gray-100">
                                        <div>@pr.EventName</div>
                                        @if (pr.IsRelay)
                                        {
                                            <div class="text-xs text-gray-500 dark:text-gray-400 mt-0.5">
                                                @for (int mi = 0; mi < pr.RelayMembers.Length; mi++)
                                                {
                                                    var member = pr.RelayMembers[mi];
                                                    var parts = member.Trim().Split(' ');
                                                    var memberSlug = parts.Length >= 2
                                                        ? new SlugHelper().GenerateSlug($"{parts[0]}-{parts[1]}")
                                                        : new SlugHelper().GenerateSlug(member);
                                                    <a asp-controller="Roster" asp-action="Details" asp-route-slug="@memberSlug" class="underline hover:text-gray-700 dark:hover:text-gray-200">@member</a>@if (mi < pr.RelayMembers.Length - 1){<span> / </span>}
                                                }
                                            </div>
                                        }
                                    </td>
                                    <td class="px-4 py-3 font-mono font-bold text-gray-900 dark:text-gray-100">@pr.Performance</td>
                                    <td class="px-4 py-3 text-sm text-gray-600 dark:text-gray-400">@pr.Date.ToString("MMM d, yyyy")</td>
                                    <td class="px-4 py-3 text-sm text-gray-900 dark:text-gray-100">
                                        @{ var helper = new SlugHelper(); var meetSlug = helper.GenerateSlug(pr.MeetName); }
                                        <a asp-controller="Meets" asp-action="Details" asp-route-slug="@meetSlug" class="underline">@pr.MeetName</a>
                                    </td>
                                    @if (hasAnyRank)
                                    {
                                        <td class="px-4 py-3 text-center">
                                            <div class="flex justify-center gap-1 flex-wrap">
                                                @if (pr.IsSchoolRecord)
                                                {
                                                    <span class="inline-block px-2 py-1 text-xs font-semibold rounded bg-yellow-100 text-yellow-800 dark:bg-yellow-900 dark:text-yellow-200">SR</span>
                                                }
                                                @if (pr.AllTimeRank.HasValue)
                                                {
                                                    <span class="inline-block px-2 py-1 text-xs font-semibold rounded bg-purple-100 text-purple-800 dark:bg-purple-900 dark:text-purple-200">#@pr.AllTimeRank AT</span>
                                                }
                                            </div>
                                        </td>
                                    }
                                </tr>
                            }
                        </tbody>
                    </table>
                }

                @if (Model.PersonalRecords.Where(x => x.Environment == CloverleafTrack.Models.Enums.Environment.Indoor).Any())
                {
                    <div class="bg-blue-50 dark:bg-blue-900/20 border-y border-blue-200 dark:border-blue-800/30 px-6 py-3 @(Model.PersonalRecords.Where(x => x.Environment == CloverleafTrack.Models.Enums.Environment.Outdoor).Any() ? "mt-2" : "")">
                        <div class="flex items-center gap-3">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-blue-600 dark:text-blue-500" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                                <path fill-rule="evenodd" d="M2.25 8.25a.75.75 0 01.75-.75h.75V6A3.75 3.75 0 017.5 2.25h9A3.75 3.75 0 0120.25 6v1.5h.75a.75.75 0 01.75.75V11a.75.75 0 01-.75.75h-.75V20a.75.75 0 01-.75.75H4.5A.75.75 0 013.75 20v-8.25H3a.75.75 0 01-.75-.75V8.25zM6 6a1.5 1.5 0 011.5-1.5h9A1.5 1.5 0 0118 6v1.5H6V6zM7.5 17.25a.75.75 0 01-.75-.75v-3A.75.75 0 017.5 12.75h3a.75.75 0 01.75.75v3a.75.75 0 01-.75.75h-3z" clip-rule="evenodd" />
                            </svg>
                            <h3 class="font-bold text-lg text-blue-700 dark:text-blue-400 uppercase tracking-wider">Indoor</h3>
                        </div>
                    </div>

                    <table class="min-w-full">
                        <thead class="bg-gray-100 dark:bg-gray-700">
                            <tr>
                                <th class="px-4 py-3 text-left text-sm font-semibold text-gray-900 dark:text-white">Event</th>
                                <th class="px-4 py-3 text-left text-sm font-semibold text-gray-900 dark:text-white">PR</th>
                                <th class="px-4 py-3 text-left text-sm font-semibold text-gray-900 dark:text-white">Date</th>
                                <th class="px-4 py-3 text-left text-sm font-semibold text-gray-900 dark:text-white">Meet</th>
                                @if (hasAnyRank)
                                {
                                    <th class="px-4 py-3 text-center text-sm font-semibold text-gray-900 dark:text-white">Rank</th>
                                }
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-200 dark:divide-gray-700">
                            @foreach (var pr in Model.PersonalRecords.Where(x => x.Environment == CloverleafTrack.Models.Enums.Environment.Indoor))
                            {
                                <tr class="hover:bg-gray-200 dark:hover:bg-gray-600">
                                    <td class="px-4 py-3 text-gray-900 dark:text-gray-100">
                                        <div>@pr.EventName</div>
                                        @if (pr.IsRelay)
                                        {
                                            <div class="text-xs text-gray-500 dark:text-gray-400 mt-0.5">
                                                @for (int mi = 0; mi < pr.RelayMembers.Length; mi++)
                                                {
                                                    var member = pr.RelayMembers[mi];
                                                    var parts = member.Trim().Split(' ');
                                                    var memberSlug = parts.Length >= 2
                                                        ? new SlugHelper().GenerateSlug($"{parts[0]}-{parts[1]}")
                                                        : new SlugHelper().GenerateSlug(member);
                                                    <a asp-controller="Roster" asp-action="Details" asp-route-slug="@memberSlug" class="underline hover:text-gray-700 dark:hover:text-gray-200">@member</a>@if (mi < pr.RelayMembers.Length - 1){<span> / </span>}
                                                }
                                            </div>
                                        }
                                    </td>
                                    <td class="px-4 py-3 font-mono font-bold text-gray-900 dark:text-gray-100">@pr.Performance</td>
                                    <td class="px-4 py-3 text-sm text-gray-600 dark:text-gray-400">@pr.Date.ToString("MMM d, yyyy")</td>
                                    <td class="px-4 py-3 text-sm text-gray-900 dark:text-gray-100">
                                        @{ var helper2 = new SlugHelper(); var meetSlug2 = helper2.GenerateSlug(pr.MeetName); }
                                        <a asp-controller="Meets" asp-action="Details" asp-route-slug="@meetSlug2" class="underline">@pr.MeetName</a>
                                    </td>
                                    @if (hasAnyRank)
                                    {
                                        <td class="px-4 py-3 text-center">
                                            <div class="flex justify-center gap-1 flex-wrap">
                                                @if (pr.IsSchoolRecord)
                                                {
                                                    <span class="inline-block px-2 py-1 text-xs font-semibold rounded bg-yellow-100 text-yellow-800 dark:bg-yellow-900 dark:text-yellow-200">SR</span>
                                                }
                                                @if (pr.AllTimeRank.HasValue)
                                                {
                                                    <span class="inline-block px-2 py-1 text-xs font-semibold rounded bg-purple-100 text-purple-800 dark:bg-purple-900 dark:text-purple-200">#@pr.AllTimeRank AT</span>
                                                }
                                            </div>
                                        </td>
                                    }
                                </tr>
                            }
                        </tbody>
                    </table>
                }

            </div>
        </div>
    }
    else
    {
        <div class="mb-8">
            <h2 class="text-2xl font-bold mb-4 text-gray-900 dark:text-white">Personal Records</h2>
            <div class="bg-white dark:bg-gray-800 rounded-lg border border-gray-200 dark:border-gray-700 overflow-hidden">
                <div class="p-12 text-center">
                    <svg class="w-16 h-16 mx-auto mb-4 text-gray-300 dark:text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"></path>
                    </svg>
                    <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-2">No Performances Yet</h3>
                    <p class="text-sm text-gray-600 dark:text-gray-400">Check back after this athlete competes in their first meet.</p>
                </div>
            </div>
        </div>
    }

    <!-- Performance by Season -->
    @if (Model.Seasons.Any())
    {
        <div class="mb-8">
            <h2 class="text-2xl font-bold mb-4 text-gray-900 dark:text-white">Performance by Season</h2>

            @foreach (var season in Model.Seasons)
            {
                <div class="mb-4 bg-white dark:bg-gray-800 rounded-lg border border-gray-200 dark:border-gray-700">
                    <button type="button"
                            class="season-toggle w-full hover:bg-gray-100 dark:hover:bg-gray-700 p-4 flex items-center justify-between transition-colors border-b border-gray-200 dark:border-gray-700"
                            data-season="@season.SeasonName.Replace(" ", "-")"
                            aria-expanded="false">
                        <div class="flex items-center gap-3">
                            <svg class="w-5 h-5 text-gray-400 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                            </svg>
                            <span class="text-lg font-semibold text-gray-900 dark:text-white">@season.SeasonName</span>
                        </div>
                        <div class="flex gap-4 text-sm">
                            <span class="text-gray-600 dark:text-gray-400">@season.PRCount PRs</span>
                            @if (season.SchoolRecordCount > 0)
                            {
                                <span class="text-yellow-600 dark:text-yellow-400">@season.SchoolRecordCount School Records</span>
                            }
                        </div>
                    </button>

                    <div class="season-content hidden p-6">
                        @foreach (var env in new[] { CloverleafTrack.Models.Enums.Environment.Outdoor, CloverleafTrack.Models.Enums.Environment.Indoor })
                        {
                            var envGroups = season.EventGroups.Where(x => x.Environment == env).ToList();
                            if (!envGroups.Any()) continue;

                            var isOutdoor = env == CloverleafTrack.Models.Enums.Environment.Outdoor;
                            var envHeaderClass = isOutdoor
                                ? "bg-amber-50 dark:bg-yellow-900/20 border-y border-yellow-200 dark:border-yellow-800/30"
                                : "bg-blue-50 dark:bg-blue-900/20 border-y border-blue-200 dark:border-blue-800/30 mt-8";

                            <div class="@envHeaderClass -mx-6 px-6 py-3 mb-6 -mt-6">
                                <div class="flex items-center gap-3">
                                    @if (isOutdoor)
                                    {
                                        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-amber-600 dark:text-yellow-500" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                                            <path fill-rule="evenodd" d="M12 2.25a.75.75 0 01.75.75v1.5a.75.75 0 01-1.5 0V3A.75.75 0 0112 2.25zM17.47 4.53a.75.75 0 011.06 1.06l-1.06 1.06a.75.75 0 11-1.06-1.06l1.06-1.06zM21.75 12a.75.75 0 01-.75.75h-1.5a.75.75 0 010-1.5H21a.75.75 0 01.75.75zM17.47 19.47a.75.75 0 00-1.06-1.06l-1.06 1.06a.75.75 0 001.06 1.06l1.06-1.06zM12 20.25a.75.75 0 01-.75-.75v-1.5a.75.75 0 011.5 0v1.5a.75.75 0 01-.75.75zM6.53 19.47a.75.75 0 001.06-1.06L6.53 17.35a.75.75 0 00-1.06 1.06l1.06 1.06zM2.25 12a.75.75 0 01.75-.75h1.5a.75.75 0 010 1.5H3a.75.75 0 01-.75-.75zM6.53 4.53a.75.75 0 00-1.06 1.06L6.53 6.65a.75.75 0 001.06-1.06L6.53 4.53zM12 6.75a5.25 5.25 0 100 10.5 5.25 5.25 0 000-10.5z" clip-rule="evenodd" />
                                        </svg>
                                        <h3 class="font-bold text-lg text-amber-800 dark:text-yellow-400 uppercase tracking-wider">Outdoor</h3>
                                    }
                                    else
                                    {
                                        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-blue-600 dark:text-blue-500" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                                            <path fill-rule="evenodd" d="M2.25 8.25a.75.75 0 01.75-.75h.75V6A3.75 3.75 0 017.5 2.25h9A3.75 3.75 0 0120.25 6v1.5h.75a.75.75 0 01.75.75V11a.75.75 0 01-.75.75h-.75V20a.75.75 0 01-.75.75H4.5A.75.75 0 013.75 20v-8.25H3a.75.75 0 01-.75-.75V8.25zM6 6a1.5 1.5 0 011.5-1.5h9A1.5 1.5 0 0118 6v1.5H6V6zM7.5 17.25a.75.75 0 01-.75-.75v-3A.75.75 0 017.5 12.75h3a.75.75 0 01.75.75v3a.75.75 0 01-.75.75h-3z" clip-rule="evenodd" />
                                        </svg>
                                        <h3 class="font-bold text-lg text-blue-700 dark:text-blue-400 uppercase tracking-wider">Indoor</h3>
                                    }
                                </div>
                            </div>

                            @foreach (var eventGroup in envGroups)
                            {
                                <div class="mb-6 last:mb-0">
                                    <div class="flex items-baseline gap-3 mb-3">
                                        <h3 class="text-lg font-semibold text-gray-900 dark:text-white">@eventGroup.EventName</h3>
                                        @if (!string.IsNullOrEmpty(eventGroup.PersonalRecordPerformance))
                                        {
                                            <span class="text-sm text-gray-600 dark:text-gray-400">
                                                PR: @eventGroup.PersonalRecordPerformance (@eventGroup.PersonalRecordDate.ToString("MMM d, yyyy"))
                                            </span>
                                        }
                                    </div>

                                    <div class="space-y-2">
                                        @foreach (var perf in eventGroup.Performances)
                                        {
                                            <div class="p-3 rounded transition-colors @(perf.IsPersonalBest ? "bg-green-50 dark:bg-green-900/40 border-l-4 border-green-500 hover:bg-green-100 dark:hover:bg-green-900/60" : "bg-gray-50 dark:bg-gray-700 hover:bg-gray-100 dark:hover:bg-gray-600")">
                                                <div class="flex items-center gap-4">
                                                    <div class="font-mono font-bold w-24 text-gray-900 dark:text-gray-100">@perf.Performance</div>
                                                    <div class="text-sm text-gray-600 dark:text-gray-400 w-24">@perf.Date.ToString("MMM d")</div>
                                                    <div class="text-sm flex-1 min-w-0 text-gray-900 dark:text-gray-100">
                                                        @{ var h = new SlugHelper(); var ms = h.GenerateSlug(perf.MeetName); }
                                                        <a asp-controller="Meets" asp-action="Details" asp-route-slug="@ms" class="underline block truncate">@perf.MeetName</a>
                                                    </div>
                                                    <div class="flex gap-1">
                                                        @if (perf.IsSchoolRecord)
                                                        {
                                                            <span class="px-2 py-0.5 text-xs font-semibold rounded bg-yellow-100 text-yellow-800 dark:bg-yellow-900 dark:text-yellow-200">SR</span>
                                                        }
                                                        @if (perf.IsPersonalBest)
                                                        {
                                                            <span class="px-2 py-0.5 text-xs font-semibold rounded bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-200">PR</span>
                                                        }
                                                        else if (perf.IsSeasonBest)
                                                        {
                                                            <span class="px-2 py-0.5 text-xs font-semibold rounded bg-blue-100 text-blue-800 dark:bg-blue-900 dark:text-blue-200">SB</span>
                                                        }
                                                        @if (perf.AllTimeRank.HasValue)
                                                        {
                                                            <span class="px-2 py-0.5 text-xs font-semibold rounded bg-purple-100 text-purple-800 dark:bg-purple-900 dark:text-purple-200">#@perf.AllTimeRank AT</span>
                                                        }
                                                    </div>
                                                </div>
                                                @if (perf.IsRelay)
                                                {
                                                    <div class="mt-1.5 ml-28 text-xs text-gray-500 dark:text-gray-400">
                                                        @for (int mi = 0; mi < perf.RelayMembers.Length; mi++)
                                                        {
                                                            var member = perf.RelayMembers[mi];
                                                            var parts = member.Trim().Split(' ');
                                                            var memberSlug = parts.Length >= 2
                                                                ? new SlugHelper().GenerateSlug($"{parts[0]}-{parts[1]}")
                                                                : new SlugHelper().GenerateSlug(member);
                                                            <a asp-controller="Roster" asp-action="Details" asp-route-slug="@memberSlug" class="underline hover:text-gray-700 dark:hover:text-gray-200">@member</a>@if (mi < perf.RelayMembers.Length - 1){<span> / </span>}
                                                        }
                                                    </div>
                                                }
                                            </div>
                                        }
                                    </div>
                                </div>
                            }
                        }
                    </div>
                </div>
            }
        </div>
    }

</div>

@functions {
    static string FormatImprovement(double delta, bool isField)
    {
        if (isField)
        {
            int totalInches = (int)Math.Round(delta);
            int feet = totalInches / 12;
            int inches = totalInches % 12;
            return feet > 0 ? $"{feet}' {inches}\"" : $"{inches}\"";
        }
        else
        {
            if (delta >= 60)
            {
                int mins = (int)(delta / 60);
                double secs = delta % 60;
                return $"{mins}:{secs:00.00}";
            }
            return delta.ToString("0.00") + "s";
        }
    }
}

@section Scripts {
<script>
    document.addEventListener('DOMContentLoaded', function () {
        const toggleButtons = document.querySelectorAll('.season-toggle');
        toggleButtons.forEach(button => {
            button.addEventListener('click', function () {
                const content = this.nextElementSibling;
                const arrow = this.querySelector('svg');
                const isExpanded = this.getAttribute('aria-expanded') === 'true';
                content.classList.toggle('hidden');
                arrow.classList.toggle('rotate-180');
                this.setAttribute('aria-expanded', isExpanded ? 'false' : 'true');
            });
        });

        if (toggleButtons.length > 0) {
            toggleButtons[0].click();
        }

        const inactiveClasses = ['border-gray-300', 'dark:border-gray-600', 'text-gray-600', 'dark:text-gray-300'];
        document.querySelectorAll('.career-tab').forEach(btn => {
            btn.addEventListener('click', function () {
                const targetId = this.dataset.target;
                document.querySelectorAll('.career-tab').forEach(t => {
                    t.dataset.activeClass.split(' ').forEach(c => t.classList.remove(c));
                    inactiveClasses.forEach(c => t.classList.add(c));
                    t.setAttribute('aria-selected', 'false');
                });
                inactiveClasses.forEach(c => this.classList.remove(c));
                this.dataset.activeClass.split(' ').forEach(c => this.classList.add(c));
                this.setAttribute('aria-selected', 'true');
                document.querySelectorAll('.career-panel').forEach(p => p.classList.add('hidden'));
                const panel = document.getElementById(targetId);
                if (panel) panel.classList.remove('hidden');
            });
        });
    });
</script>
}
