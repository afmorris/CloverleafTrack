@model CloverleafTrack.ViewModels.Meets.TeamResultViewModel

@if (Model.HasResult)
{
    var isDual = Model.MeetType == CloverleafTrack.Models.Enums.MeetType.Dual
              || Model.MeetType == CloverleafTrack.Models.Enums.MeetType.DoubleDual;
    <div class="flex flex-wrap gap-1.5">
        @foreach (var entry in Model.Entries.Where(e => e.Label.Length > 0))
        {
            if (isDual)
            {
                <span class="@(entry.Won ? "chip-win" : "chip-loss")">@entry.Label</span>
            }
            else
            {
                <span class="chip-rank">@entry.Label</span>
            }
        }
    </div>
}
