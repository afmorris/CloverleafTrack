@model HomePageViewModel

@if (Model.LatestMeetImpact != null)
{
    var impact = Model.LatestMeetImpact;
    var hasLocation = !string.IsNullOrWhiteSpace(impact.LocationName)
        || !string.IsNullOrWhiteSpace(impact.LocationCity)
        || !string.IsNullOrWhiteSpace(impact.LocationState);
    var locationParts = new[] { impact.LocationName, impact.LocationCity, impact.LocationState }
        .Where(part => !string.IsNullOrWhiteSpace(part));
    var environmentLabel = impact.Environment == CloverleafTrack.Models.Enums.Environment.Indoor ? "Indoor" : "Outdoor";

    <section class="mb-8">
        <div class="bg-white dark:bg-gray-800 rounded-lg border border-gray-200 dark:border-gray-700 overflow-hidden">
            <div class="px-5 py-4 border-b border-gray-200 dark:border-gray-700">
                <div class="text-xs font-semibold uppercase tracking-wide text-gray-400 dark:text-gray-500 mb-1">Latest meet</div>
                <h2 class="text-xl font-bold text-gray-900 dark:text-white leading-tight">
                    <a asp-controller="Meets" asp-action="Details" asp-route-slug="@impact.MeetSlug"
                       class="underline underline-offset-2 hover:text-ctf-darkaccent dark:hover:text-ctf-accent">
                        @impact.MeetName
                    </a>
                </h2>
                <div class="mt-1 flex flex-wrap gap-x-3 gap-y-0.5 text-sm text-gray-500 dark:text-gray-400">
                    <span>@impact.Date.ToString("MMM d, yyyy")</span>
                    <span>@environmentLabel</span>
                    @if (hasLocation)
                    {
                        <span>@string.Join(", ", locationParts)</span>
                    }
                </div>
            </div>

            <div class="metric-strip">
                <div class="metric-cell">
                    <span class="metric-value">@impact.TotalPerformances</span>
                    <span class="metric-label">Performances</span>
                </div>
                <div class="metric-cell">
                    <span class="metric-value text-pr">@impact.TotalPRs</span>
                    <span class="metric-label">PRs</span>
                </div>
                <div class="metric-cell">
                    <span class="metric-value text-sr">@impact.TotalSchoolRecords</span>
                    <span class="metric-label">Records</span>
                </div>
                <div class="metric-cell">
                    <span class="metric-value">@impact.TopTenAllTimeMarks</span>
                    <span class="metric-label">Top-10</span>
                </div>
            </div>
        </div>
    </section>
}
