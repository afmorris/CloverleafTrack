@model HomePageViewModel

@if (Model.LatestMeetImpact != null)
{
    var impact = Model.LatestMeetImpact;
    var hasLocation = !string.IsNullOrWhiteSpace(impact.LocationName)
        || !string.IsNullOrWhiteSpace(impact.LocationCity)
        || !string.IsNullOrWhiteSpace(impact.LocationState);
    var locationParts = new[] { impact.LocationName, impact.LocationCity, impact.LocationState }
        .Where(part => !string.IsNullOrWhiteSpace(part));
    var environmentLabel = impact.Environment == CloverleafTrack.Models.Enums.Environment.Indoor ? "Indoor" : "Outdoor";

    <section class="mb-12">
        <div class="bg-white dark:bg-gray-800 rounded-lg border border-gray-200 dark:border-gray-700 overflow-hidden">
            <div class="px-6 py-5 border-b border-gray-200 dark:border-gray-700">
                <div class="flex flex-wrap items-start justify-between gap-4">
                    <div>
                        <div class="text-xs font-semibold uppercase tracking-wide text-gray-500 dark:text-gray-400 mb-1">Latest Meet Impact</div>
                        <h2 class="text-2xl font-bold text-gray-900 dark:text-white">
                            <a asp-controller="Meets" asp-action="Details" asp-route-slug="@impact.MeetSlug" class="underline underline-offset-4 hover:text-gray-700 dark:hover:text-gray-200">
                                @impact.MeetName
                            </a>
                        </h2>
                        <div class="mt-2 flex flex-wrap gap-x-4 gap-y-1 text-sm text-gray-600 dark:text-gray-400">
                            <span>@impact.Date.ToString("MMMM d, yyyy")</span>
                            <span>@environmentLabel</span>
                            @if (hasLocation)
                            {
                                <span>@string.Join(", ", locationParts)</span>
                            }
                        </div>
                    </div>
                </div>
            </div>

            <div class="grid grid-cols-2 md:grid-cols-4 gap-4 p-6">
                <div class="bg-gray-50 dark:bg-gray-700 rounded-lg p-5">
                    <div class="text-xs text-gray-500 dark:text-gray-400 mb-1 font-semibold uppercase tracking-wide">Performances</div>
                    <div class="text-3xl font-bold text-gray-900 dark:text-white">@impact.TotalPerformances</div>
                </div>
                <div class="bg-gray-50 dark:bg-gray-700 rounded-lg p-5">
                    <div class="text-xs text-gray-500 dark:text-gray-400 mb-1 font-semibold uppercase tracking-wide">Athletes</div>
                    <div class="text-3xl font-bold text-gray-900 dark:text-white">@impact.UniqueAthletes</div>
                </div>
                <div class="bg-gray-50 dark:bg-gray-700 rounded-lg p-5">
                    <div class="text-xs text-green-700 dark:text-green-300 mb-1 font-semibold uppercase tracking-wide">PRs</div>
                    <div class="text-3xl font-bold text-green-700 dark:text-green-300">@impact.TotalPRs</div>
                </div>
                <div class="bg-gray-50 dark:bg-gray-700 rounded-lg p-5">
                    <div class="text-xs text-yellow-700 dark:text-yellow-300 mb-1 font-semibold uppercase tracking-wide">School Records</div>
                    <div class="text-3xl font-bold text-yellow-700 dark:text-yellow-300">@impact.TotalSchoolRecords</div>
                </div>
                <div class="bg-gray-50 dark:bg-gray-700 rounded-lg p-5">
                    <div class="text-xs text-purple-700 dark:text-purple-300 mb-1 font-semibold uppercase tracking-wide">Top-10 Marks</div>
                    <div class="text-3xl font-bold text-purple-700 dark:text-purple-300">@impact.TopTenAllTimeMarks</div>
                </div>
            </div>
        </div>
    </section>
}
