@model HomePageViewModel

<div class="metric-strip mb-6">
    <div class="metric-cell">
        <span class="metric-value text-pr">@Model.TotalPRsThisSeason</span>
        <span class="metric-label">Season PRs</span>
    </div>
    <div class="metric-cell">
        <span class="metric-value text-sr">@Model.SchoolRecordsBroken</span>
        <span class="metric-label">Records</span>
    </div>
    <div class="metric-cell">
        <span class="metric-value">@Model.ActiveAthletes</span>
        <span class="metric-label">Athletes</span>
    </div>
    <div class="metric-cell">
        <span class="metric-value">@Model.MeetsCompleted<span class="text-base font-normal text-gray-400 dark:text-gray-500">/@Model.TotalMeetsThisSeason</span></span>
        <span class="metric-label">Meets</span>
    </div>
</div>
