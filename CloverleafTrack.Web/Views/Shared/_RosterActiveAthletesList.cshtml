@model RosterViewModel

<div class="mb-16">
    <div class="flex items-center justify-between mb-6">
        <h2 class="text-2xl font-bold text-gray-900 dark:text-white">Current Roster</h2>
        <span class="text-sm text-gray-500 dark:text-gray-400">@Model.FlatActiveAthletes.Count athletes</span>
    </div>

    @if (Model.FlatActiveAthletes.Any())
    {
        <!-- Filter chips -->
        <div class="flex flex-wrap gap-x-6 gap-y-3 mb-6 p-4 bg-white dark:bg-gray-800 rounded-lg border border-gray-200 dark:border-gray-700">
            @await Html.PartialAsync("_FilterChipGroup", null, new ViewDataDictionary(ViewData) {
                ["Label"] = "Gender",
                ["FilterKey"] = "gender",
                ["Options"] = new List<(string, string)> { ("all","All"), ("boys","Boys"), ("girls","Girls") }
            })
            @await Html.PartialAsync("_FilterChipGroup", null, new ViewDataDictionary(ViewData) {
                ["Label"] = "Category",
                ["FilterKey"] = "categories",
                ["Options"] = new List<(string, string)> { ("all","All"), ("sprints","Sprints"), ("distance","Distance"), ("hurdles","Hurdles"), ("jumps","Jumps"), ("throws","Throws") }
            })
        </div>

        <div class="bg-white dark:bg-gray-800 rounded-lg border border-gray-200 dark:border-gray-700 overflow-hidden" data-filterable-container>
            <div class="overflow-x-auto">
                <table class="w-full text-sm">
                    <thead class="bg-gray-50 dark:bg-gray-700/50 text-xs uppercase tracking-wide text-gray-500 dark:text-gray-400">
                        <tr>
                            <th class="px-4 py-2.5 text-left font-medium">Name</th>
                            <th class="px-4 py-2.5 text-left font-medium hidden sm:table-cell">Class</th>
                            <th class="px-4 py-2.5 text-left font-medium hidden sm:table-cell">Gender</th>
                            <th class="px-4 py-2.5 text-left font-medium hidden md:table-cell">Top Event</th>
                            <th class="px-4 py-2.5 text-left font-medium">Best Mark</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-100 dark:divide-gray-700">
                        @foreach (var athlete in Model.FlatActiveAthletes)
                        {
                            var genderVal = athlete.Gender == CloverleafTrack.Models.Enums.Gender.Male ? "boys" : "girls";
                            var categoriesVal = string.Join(",", athlete.Categories.Select(c => c.ToString().ToLower()));
                            var topEvent = athlete.EventsInCategory.FirstOrDefault();
                            <tr class="hover:bg-gray-50 dark:hover:bg-gray-700/50"
                                data-filterable
                                data-gender="@genderVal"
                                data-categories="@categoriesVal">
                                <td class="px-4 py-2.5">
                                    <a href="@Url.Action("Details", "Roster", new { slug = athlete.AthleteSlug })"
                                       class="flex items-center gap-1.5 font-medium text-gray-900 dark:text-white hover:text-ctf-darkaccent dark:hover:text-ctf-accent">
                                        <span class="w-2 h-2 rounded-full bg-green-500 inline-block flex-shrink-0" aria-label="Active athlete"></span>
                                        @athlete.FullName
                                    </a>
                                </td>
                                <td class="px-4 py-2.5 text-gray-500 dark:text-gray-400 hidden sm:table-cell">@athlete.Class</td>
                                <td class="px-4 py-2.5 hidden sm:table-cell">
                                    @if (athlete.Gender == CloverleafTrack.Models.Enums.Gender.Male)
                                    {
                                        <span class="text-blue-500 dark:text-blue-400 font-medium text-xs">M</span>
                                    }
                                    else
                                    {
                                        <span class="text-pink-500 dark:text-pink-400 font-medium text-xs">F</span>
                                    }
                                </td>
                                <td class="px-4 py-2.5 text-gray-600 dark:text-gray-400 truncate max-w-[160px] hidden md:table-cell">@(topEvent?.Name ?? "")</td>
                                <td class="px-4 py-2.5">
                                    @if (topEvent != null)
                                    {
                                        <span class="mark font-semibold text-gray-900 dark:text-white">@topEvent.PersonalRecord</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div id="roster-empty" class="hidden p-8 text-center text-gray-500 dark:text-gray-400 bg-white dark:bg-gray-800 rounded-lg border border-gray-200 dark:border-gray-700 mt-4">
            No athletes match the selected filters.
        </div>
    }
    else
    {
        <div class="p-8 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl text-center">
            <p class="text-gray-600 dark:text-gray-400">No active athletes found.</p>
        </div>
    }
</div>
