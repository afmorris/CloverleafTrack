@{
    var currentPath = Context.Request.Path;

    var links = new[]
    {
        new { Href = "/",            Text = "Results",  Icon = "results"  },
        new { Href = "/roster",      Text = "Athletes", Icon = "athletes" },
        new { Href = "/leaderboard", Text = "Records",  Icon = "records"  },
        new { Href = "/meets",       Text = "Meets",    Icon = "meets"    },
    };
}

@* Desktop nav (≥640px) — sits inline in the header *@
<nav class="hidden sm:flex items-center gap-6 font-heading text-sm uppercase tracking-wide font-semibold text-gray-100"
     aria-label="Main navigation">
    @foreach (var link in links)
    {
        var isActive = link.Href == "/"
            ? currentPath.Equals(new PathString("/"))
            : currentPath.StartsWithSegments(new PathString(link.Href), StringComparison.OrdinalIgnoreCase);
        var cls = isActive ? "transition-colors duration-200 text-ctf-accent underline underline-offset-4" : "transition-colors duration-200 hover:text-ctf-accent";
        <a href="@link.Href" class="@cls rounded focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white" @(isActive ? Html.Raw("aria-current=\"page\"") : Html.Raw(""))>@link.Text</a>
    }
</nav>

@* Mobile bottom tab bar (≤640px) — fixed, full-width *@
<nav class="sm:hidden fixed bottom-0 inset-x-0 bg-ctf-nav border-t border-white/10 z-50 bottom-nav flex"
     aria-label="Main navigation">
    @foreach (var link in links)
    {
        var isActive = link.Href == "/"
            ? currentPath.Equals(new PathString("/"))
            : currentPath.StartsWithSegments(new PathString(link.Href), StringComparison.OrdinalIgnoreCase);
        <a href="@link.Href"
           class="tab-item @(isActive ? "tab-item-active" : "")"
           @(isActive ? Html.Raw("aria-current=\"page\"") : Html.Raw(""))>

            @if (link.Icon == "results")
            {
                <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <rect x="18" y="3" width="3" height="18" rx="1"/>
                    <rect x="11" y="8" width="3" height="13" rx="1"/>
                    <rect x="4" y="13" width="3" height="8" rx="1"/>
                </svg>
            }
            else if (link.Icon == "athletes")
            {
                <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/>
                    <circle cx="9" cy="7" r="4"/>
                    <path stroke-linecap="round" stroke-linejoin="round" d="M23 21v-2a4 4 0 00-3-3.87"/>
                    <path stroke-linecap="round" stroke-linejoin="round" d="M16 3.13a4 4 0 010 7.75"/>
                </svg>
            }
            else if (link.Icon == "records")
            {
                <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M8 21h8M12 17v4"/>
                    <path stroke-linecap="round" stroke-linejoin="round" d="M7 4H4v5c0 2.76 2.24 4.5 3 4.5M17 4h3v5c0 2.76-2.24 4.5-3 4.5"/>
                    <path stroke-linecap="round" stroke-linejoin="round" d="M7 4h10v7a5 5 0 01-10 0V4z"/>
                </svg>
            }
            else
            {
                <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
                    <line x1="16" y1="2" x2="16" y2="6"/>
                    <line x1="8" y1="2" x2="8" y2="6"/>
                    <line x1="3" y1="10" x2="21" y2="10"/>
                </svg>
            }
            <span class="font-medium" style="font-size:11px">@link.Text</span>
        </a>
    }
</nav>
