@model MeetsIndexViewModel

<div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
    <div class="bg-white dark:bg-gray-800 rounded-lg p-5 border border-purple-200 dark:border-purple-700/30">
        <div class="text-xs text-purple-700 dark:text-purple-300 mb-2 uppercase tracking-wide font-semibold">Total Meets</div>
        <div class="text-3xl font-bold text-purple-900 dark:text-purple-100 mb-1">@Model.TotalMeets</div>
        <div class="text-xs text-purple-600 dark:text-purple-400">All time</div>
    </div>
    <div class="bg-white dark:bg-gray-800 rounded-lg p-5 border border-blue-200 dark:border-blue-700/30">
        <div class="text-xs text-blue-700 dark:text-blue-300 mb-2 uppercase tracking-wide font-semibold">Total PRs</div>
        <div class="text-3xl font-bold text-blue-900 dark:text-blue-100 mb-1">@Model.TotalPRs</div>
        <div class="text-xs text-blue-600 dark:text-blue-400">Personal records</div>
    </div>
    <div class="bg-white dark:bg-gray-800 rounded-lg p-5 border border-yellow-200 dark:border-yellow-700/30">
        <div class="text-xs text-yellow-700 dark:text-yellow-300 mb-2 uppercase tracking-wide font-semibold">School Records</div>
        <div class="text-3xl font-bold text-yellow-900 dark:text-yellow-100 mb-1">@Model.TotalSchoolRecords</div>
        <div class="text-xs text-yellow-600 dark:text-yellow-400">Broken records</div>
    </div>
    <div class="bg-white dark:bg-gray-800 rounded-lg p-5 border border-green-200 dark:border-green-700/30">
        <div class="text-xs text-green-700 dark:text-green-300 mb-2 uppercase tracking-wide font-semibold">Seasons</div>
        <div class="text-3xl font-bold text-green-900 dark:text-green-100 mb-1">@Model.TotalSeasons</div>
        <div class="text-xs text-green-600 dark:text-green-400">Years tracked</div>
    </div>
</div>
