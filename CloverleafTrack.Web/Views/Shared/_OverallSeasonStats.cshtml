@using CloverleafTrack.ViewModels.Seasons;

@model List<SeasonCardViewModel>

@{
    var totalSeasons = Model.Count;
	var totalOutdoorSRs = Model.Sum(s => s.OutdoorSchoolRecordCount);
	var totalIndoorSRs = Model.Sum(s => s.IndoorSchoolRecordCount);
	var totalMeets = Model.Sum(s => s.TotalMeets);
}

<div class="mb-12">
    <h2 class="text-2xl font-bold mb-6 text-gray-900 dark:text-white">All-Time Program Stats</h2>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        <div class="bg-white dark:bg-gray-800 rounded-xl p-6 border border-purple-200 dark:border-purple-700/30">
            <div class="text-sm text-purple-700 dark:text-purple-300 mb-2 font-semibold uppercase tracking-wide">Total Seasons</div>
            <div class="text-4xl font-bold text-purple-900 dark:text-purple-100">@totalSeasons</div>
        </div>
        <div class="bg-white dark:bg-gray-800 rounded-xl p-6 border border-blue-200 dark:border-blue-700/30">
            <div class="text-sm text-blue-700 dark:text-blue-300 mb-2 font-semibold uppercase tracking-wide">Indoor SRs</div>
            <div class="text-4xl font-bold text-blue-900 dark:text-blue-100">@totalIndoorSRs</div>
        </div>
        <div class="bg-white dark:bg-gray-800 rounded-xl p-6 border border-yellow-200 dark:border-yellow-700/30">
            <div class="text-sm text-yellow-700 dark:text-yellow-300 mb-2 font-semibold uppercase tracking-wide">Outdoor SRs</div>
            <div class="text-4xl font-bold text-yellow-900 dark:text-yellow-100">@totalOutdoorSRs</div>
        </div>
        <div class="bg-white dark:bg-gray-800 rounded-xl p-6 border border-green-200 dark:border-green-700/30">
            <div class="text-sm text-green-700 dark:text-green-300 mb-2 font-semibold uppercase tracking-wide">Total Meets</div>
            <div class="text-4xl font-bold text-green-900 dark:text-green-100">@totalMeets</div>
        </div>
    </div>
</div>
