@using Slugify
@model List<LeaderboardEventViewModel>

@functions {
    static string GetGroupLabel(int sortOrder) => sortOrder switch
    {
        < 100  => "Sprints",
        < 150  => "Hurdles",
        < 300  => "Distance",
        < 430  => "Throws",
        _      => "Jumps"
    };
}

@{
    string? currentGroup = null;
}

<div class="bg-white dark:bg-gray-800 rounded-lg border border-gray-200 dark:border-gray-700 overflow-hidden">
    <table class="w-full text-sm">
        <tbody class="divide-y divide-gray-100 dark:divide-gray-700">
            @foreach (var evt in Model.Where(x => !string.IsNullOrEmpty(x.Performance)))
            {
                var group = GetGroupLabel(evt.SortOrder);
                if (group != currentGroup)
                {
                    currentGroup = group;
                    <tr>
                        <td colspan="2" class="px-4 pt-4 pb-1.5 bg-white dark:bg-gray-800">
                            <span class="text-xs font-semibold text-gray-400 dark:text-gray-500 uppercase tracking-wider">@group</span>
                        </td>
                    </tr>
                }
                <tr class="hover:bg-gray-50 dark:hover:bg-gray-800/60 transition-colors">
                    <td class="px-4 py-2.5">
                        <a asp-controller="Leaderboard" asp-action="Details" asp-route-eventKey="@evt.EventKey.ToLower()"
                           class="font-medium text-gray-900 dark:text-white hover:underline">
                            @evt.EventName
                        </a>
                        @if (!string.IsNullOrEmpty(evt.AthleteFirstName) && !string.IsNullOrEmpty(evt.AthleteLastName))
                        {
                            <div class="text-xs text-gray-500 dark:text-gray-400 mt-0.5">
                                <a asp-controller="Roster" asp-action="Details" asp-route-slug="@evt.AthleteSlug" class="hover:underline">
                                    @evt.AthleteFullName
                                </a>
                            </div>
                        }
                        else if (!string.IsNullOrEmpty(evt.RelayName))
                        {
                            <div class="text-xs text-gray-500 dark:text-gray-400 mt-0.5">
                                @{
                                    var relayMembers = evt.RelayMembers.Where(a => !string.IsNullOrEmpty(a)).ToList();
                                    for (int ri = 0; ri < relayMembers.Count; ri++)
                                    {
                                        var athlete = relayMembers[ri];
                                        var split = athlete.Split(' ');
                                        if (split.Length >= 2)
                                        {
                                            var helper = new SlugHelper();
                                            var slug = helper.GenerateSlug($"{split[0]}-{split[1]}");
                                            <a asp-controller="Roster" asp-action="Details" asp-route-slug="@slug" class="hover:underline">@athlete</a>
                                        }
                                        else { @athlete }
                                        if (ri < relayMembers.Count - 1) { <span> / </span> }
                                    }
                                }
                            </div>
                        }
                    </td>
                    <td class="px-4 py-2.5 text-right whitespace-nowrap">
                        <span class="mark font-bold text-gray-900 dark:text-white">@evt.Performance</span>
                        @if (evt.MeetDate.HasValue)
                        {
                            <div class="text-xs text-gray-400 dark:text-gray-500 mt-0.5">
                                <a asp-controller="Meets" asp-action="Details" asp-route-slug="@evt.MeetSlug" class="hover:underline">
                                    @evt.MeetDate.Value.ToString("MMM d, yyyy")
                                </a>
                            </div>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
