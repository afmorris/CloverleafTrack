@using Slugify

@model Tuple<bool, bool, List<LeaderboardCategoryViewModel>>

@{
    string genderBorder = Model.Item1 ? "border-blue-500" : "border-pink-500";
    string genderColor  = Model.Item1 ? "text-blue-600 dark:text-blue-400" : "text-pink-600 dark:text-pink-400";
    string environmentColor = Model.Item2 ? "text-blue-700 dark:text-blue-300" : "text-yellow-600 dark:text-yellow-300";
}

@functions {
    string[] GetRelayAthletes(string athleteName) =>
        athleteName?.Split("|~|") ?? Array.Empty<string>();
}

@foreach (var category in Model.Item3)
{
    <div class="mb-8" data-filterable data-category="@category.Category.ToString().ToLower()">
        <h3 class="text-lg font-semibold mb-3 text-gray-800 dark:text-gray-300 uppercase tracking-wide">@category.CategoryName</h3>

        <div class="space-y-2">
            @foreach (var evt in category.Events.Where(x => !string.IsNullOrEmpty(x.Performance)))
            {
                <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 border-l-4 @genderBorder rounded-lg hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors">
                    <div class="p-4 flex items-center justify-between">
                        <div class="flex-1 min-w-0">
                            <a asp-controller="Leaderboard" asp-action="Details" asp-route-eventKey="@evt.EventKey.ToLower()"
                               class="font-semibold text-gray-900 dark:text-white hover:text-blue-600 dark:hover:text-blue-400 transition-colors underline">
                                @evt.EventName
                            </a>
                            @if (!string.IsNullOrEmpty(evt.AthleteFirstName) && !string.IsNullOrEmpty(evt.AthleteLastName))
                            {
                                <div class="text-sm text-gray-500 dark:text-gray-400 mt-0.5">
                                    <a asp-controller="Roster" asp-action="Details" asp-route-slug="@evt.AthleteSlug" class="underline hover:text-gray-700 dark:hover:text-gray-200">
                                        @evt.AthleteFullName
                                    </a>
                                </div>
                            }
                            else if (!string.IsNullOrEmpty(evt.RelayName))
                            {
                                <div class="text-sm text-gray-500 dark:text-gray-400 mt-0.5">
                                    @{
                                        var relayMembers = evt.RelayMembers.Where(a => !string.IsNullOrEmpty(a)).ToList();
                                        for (int ri = 0; ri < relayMembers.Count; ri++)
                                        {
                                            var athlete = relayMembers[ri];
                                            var split = athlete.Split(' ');
                                            if (split.Length >= 2)
                                            {
                                                var helper = new SlugHelper();
                                                var slug = helper.GenerateSlug($"{split[0]}-{split[1]}");
                                                <a asp-controller="Roster" asp-action="Details" asp-route-slug="@slug" class="underline hover:text-gray-700 dark:hover:text-gray-200">@athlete</a>
                                            }
                                            else
                                            {
                                                @athlete
                                            }
                                            if (ri < relayMembers.Count - 1) { <span> / </span> }
                                        }
                                    }
                                </div>
                            }
                        </div>
                        <div class="text-right flex-shrink-0 ml-4">
                            <div class="text-2xl font-bold font-mono @environmentColor">@evt.Performance</div>
                            @if (evt.MeetDate.HasValue)
                            {
                                <div class="text-xs text-gray-500 dark:text-gray-400 mt-1">
                                    <a asp-controller="Meets" asp-action="Details" asp-route-slug="@evt.MeetSlug" class="underline hover:text-gray-700 dark:hover:text-gray-200">
                                        @evt.MeetDate.Value.ToString("MMM d, yyyy")
                                    </a>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
}
