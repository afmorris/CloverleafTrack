@model HomePageViewModel

@if (Model.IndoorBreakoutAthlete != null || Model.IndoorBiggestImprovement != null || Model.IndoorTopPerformance != null ||
     Model.OutdoorBreakoutAthlete != null || Model.OutdoorBiggestImprovement != null || Model.OutdoorTopPerformance != null)
{
    <section class="mb-10">
        <h2 class="text-lg font-semibold mb-4 text-gray-900 dark:text-white">Season highlights</h2>

        <!-- Outdoor content -->
        <div data-filterable data-env="outdoor">
            <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
                @if (Model.OutdoorBreakoutAthlete != null)
                {
                    <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg p-4">
                        <div class="text-xs font-semibold uppercase tracking-wide text-gray-400 dark:text-gray-500 mb-2">Breakout athlete</div>
                        <div class="mark text-2xl font-bold text-gray-900 dark:text-white mb-1">@Model.OutdoorBreakoutAthlete.PRCount PRs</div>
                        <div class="font-medium text-gray-900 dark:text-white">
                            <a asp-controller="Roster" asp-action="Details" asp-route-slug="@Model.OutdoorBreakoutAthlete.Slug" class="underline hover:text-ctf-darkaccent dark:hover:text-ctf-accent">
                                @Model.OutdoorBreakoutAthlete.FullName
                            </a>
                        </div>
                        <div class="text-sm text-gray-500 dark:text-gray-400">@Model.OutdoorBreakoutAthlete.Class</div>
                    </div>
                }

                @if (Model.OutdoorBiggestImprovement != null)
                {
                    <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg p-4">
                        <div class="text-xs font-semibold uppercase tracking-wide text-gray-400 dark:text-gray-500 mb-2">Biggest improvement</div>
                        <div class="mark text-2xl font-bold text-pr mb-1">@Model.OutdoorBiggestImprovement.ImprovementDisplay</div>
                        <div class="font-medium text-gray-900 dark:text-white">
                            <a asp-controller="Roster" asp-action="Details" asp-route-slug="@Model.OutdoorBiggestImprovement.AthleteSlug" class="underline hover:text-ctf-darkaccent dark:hover:text-ctf-accent">
                                @Model.OutdoorBiggestImprovement.AthleteFullName
                            </a>
                        </div>
                        <div class="text-sm text-gray-500 dark:text-gray-400">@Model.OutdoorBiggestImprovement.EventName</div>
                        <div class="text-xs text-gray-400 dark:text-gray-500 mt-1">@Model.OutdoorBiggestImprovement.PreviousPerformance → @Model.OutdoorBiggestImprovement.CurrentPerformance</div>
                    </div>
                }

                @if (Model.OutdoorTopPerformance != null)
                {
                    <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg p-4">
                        <div class="text-xs font-semibold uppercase tracking-wide text-gray-400 dark:text-gray-500 mb-2">Top performance</div>
                        <div class="mark text-2xl font-bold text-gray-900 dark:text-white mb-1">
                            @Model.OutdoorTopPerformance.Performance
                            @if (Model.OutdoorTopPerformance.IsSchoolRecord) { <span class="chip-sr">SR</span> }
                            else if (Model.OutdoorTopPerformance.IsPersonalBest) { <span class="chip-pr">PR</span> }
                        </div>
                        <div class="font-medium text-gray-900 dark:text-white">
                            <a asp-controller="Roster" asp-action="Details" asp-route-slug="@Model.OutdoorTopPerformance.AthleteSlug" class="underline hover:text-ctf-darkaccent dark:hover:text-ctf-accent">
                                @Model.OutdoorTopPerformance.AthleteFullName
                            </a>
                        </div>
                        <div class="text-sm text-gray-500 dark:text-gray-400">@Model.OutdoorTopPerformance.EventName</div>
                        <div class="text-xs text-gray-400 dark:text-gray-500 mt-1">
                            <a asp-controller="Meets" asp-action="Details" asp-route-slug="@Model.OutdoorTopPerformance.MeetSlug" class="underline">
                                @Model.OutdoorTopPerformance.MeetName
                            </a>
                            · @Model.OutdoorTopPerformance.Date.ToString("MMM d, yyyy")
                        </div>
                    </div>
                }
            </div>
        </div>

        <!-- Indoor content -->
        <div data-filterable data-env="indoor">
            <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
                @if (Model.IndoorBreakoutAthlete != null)
                {
                    <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg p-4">
                        <div class="text-xs font-semibold uppercase tracking-wide text-gray-400 dark:text-gray-500 mb-2">Breakout athlete</div>
                        <div class="mark text-2xl font-bold text-gray-900 dark:text-white mb-1">@Model.IndoorBreakoutAthlete.PRCount PRs</div>
                        <div class="font-medium text-gray-900 dark:text-white">
                            <a asp-controller="Roster" asp-action="Details" asp-route-slug="@Model.IndoorBreakoutAthlete.Slug" class="underline hover:text-ctf-darkaccent dark:hover:text-ctf-accent">
                                @Model.IndoorBreakoutAthlete.FullName
                            </a>
                        </div>
                        <div class="text-sm text-gray-500 dark:text-gray-400">@Model.IndoorBreakoutAthlete.Class</div>
                    </div>
                }

                @if (Model.IndoorBiggestImprovement != null)
                {
                    <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg p-4">
                        <div class="text-xs font-semibold uppercase tracking-wide text-gray-400 dark:text-gray-500 mb-2">Biggest improvement</div>
                        <div class="mark text-2xl font-bold text-pr mb-1">@Model.IndoorBiggestImprovement.ImprovementDisplay</div>
                        <div class="font-medium text-gray-900 dark:text-white">
                            <a asp-controller="Roster" asp-action="Details" asp-route-slug="@Model.IndoorBiggestImprovement.AthleteSlug" class="underline hover:text-ctf-darkaccent dark:hover:text-ctf-accent">
                                @Model.IndoorBiggestImprovement.AthleteFullName
                            </a>
                        </div>
                        <div class="text-sm text-gray-500 dark:text-gray-400">@Model.IndoorBiggestImprovement.EventName</div>
                        <div class="text-xs text-gray-400 dark:text-gray-500 mt-1">@Model.IndoorBiggestImprovement.PreviousPerformance → @Model.IndoorBiggestImprovement.CurrentPerformance</div>
                    </div>
                }

                @if (Model.IndoorTopPerformance != null)
                {
                    <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg p-4">
                        <div class="text-xs font-semibold uppercase tracking-wide text-gray-400 dark:text-gray-500 mb-2">Top performance</div>
                        <div class="mark text-2xl font-bold text-gray-900 dark:text-white mb-1">
                            @Model.IndoorTopPerformance.Performance
                            @if (Model.IndoorTopPerformance.IsSchoolRecord) { <span class="chip-sr">SR</span> }
                            else if (Model.IndoorTopPerformance.IsPersonalBest) { <span class="chip-pr">PR</span> }
                        </div>
                        <div class="font-medium text-gray-900 dark:text-white">
                            <a asp-controller="Roster" asp-action="Details" asp-route-slug="@Model.IndoorTopPerformance.AthleteSlug" class="underline hover:text-ctf-darkaccent dark:hover:text-ctf-accent">
                                @Model.IndoorTopPerformance.AthleteFullName
                            </a>
                        </div>
                        <div class="text-sm text-gray-500 dark:text-gray-400">@Model.IndoorTopPerformance.EventName</div>
                        <div class="text-xs text-gray-400 dark:text-gray-500 mt-1">
                            <a asp-controller="Meets" asp-action="Details" asp-route-slug="@Model.IndoorTopPerformance.MeetSlug" class="underline">
                                @Model.IndoorTopPerformance.MeetName
                            </a>
                            · @Model.IndoorTopPerformance.Date.ToString("MMM d, yyyy")
                        </div>
                    </div>
                }
            </div>
        </div>
    </section>
}
