@model MeetListItemViewModel

@{
    var isOutdoor = Model.Environment == CloverleafTrack.Models.Enums.Environment.Outdoor;
    var monthColorClass = isOutdoor ? "text-amber-600 dark:text-amber-400" : "text-blue-600 dark:text-blue-400";
}

<tr class="hover:bg-gray-50 dark:hover:bg-gray-700/30 cursor-pointer"
    onclick="window.location='@Url.Action("Details", "Meets", new { slug = Model.Slug })'"
    data-filterable
    data-env="@(isOutdoor ? "outdoor" : "indoor")">
    <td class="px-4 py-3 tabular-nums w-14 flex-shrink-0">
        <div class="text-xs font-semibold @monthColorClass uppercase leading-none">@Model.Date.ToString("MMM")</div>
        <div class="text-base font-bold text-gray-900 dark:text-white leading-tight">@Model.Date.Day</div>
    </td>
    <td class="px-4 py-3">
        <div class="flex items-center gap-2 flex-wrap">
            <a asp-controller="Meets" asp-action="Details" asp-route-slug="@Model.Slug"
               class="font-medium text-gray-900 dark:text-white hover:underline"
               onclick="event.stopPropagation()">@Model.Name</a>
            @if (Model.IsUpcoming)
            {
                var daysUntil = (Model.Date.Date - DateTime.Today).Days;
                var countdown = daysUntil == 0 ? "Today"
                              : daysUntil == 1 ? "Tomorrow"
                              : $"in {daysUntil} days";
                <span class="px-2 py-0.5 bg-green-100 dark:bg-green-900/40 text-green-700 dark:text-green-400 border border-green-200 dark:border-green-700/30 rounded text-xs font-bold flex-shrink-0">@countdown</span>
            }
        </div>
    </td>
    <td class="px-4 py-3 text-gray-500 dark:text-gray-400 text-sm hidden sm:table-cell">
        @if (!string.IsNullOrEmpty(Model.LocationCity) && !string.IsNullOrEmpty(Model.LocationState))
        {
            @($"{Model.LocationCity}, {Model.LocationState}")
        }
        else if (!string.IsNullOrEmpty(Model.LocationName))
        {
            @Model.LocationName
        }
    </td>
    <td class="px-4 py-3 hidden sm:table-cell">
        @if (Model.TeamResult != null)
        {
            @await Html.PartialAsync("_TeamResultBadge", Model.TeamResult)
        }
    </td>
    <td class="px-4 py-3 hidden sm:table-cell">
        <div class="flex gap-1.5">
            @if (Model.PRCount > 0)
            {
                <span class="chip-pr">@Model.PRCount PR</span>
            }
            @if (Model.SchoolRecordCount > 0)
            {
                <span class="chip-sr">@Model.SchoolRecordCount SR</span>
            }
        </div>
    </td>
    <td class="px-4 py-3 text-right">
        <svg class="w-4 h-4 text-gray-400 inline" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
        </svg>
    </td>
</tr>
