@model HomePageViewModel

@if (Model.OnThisDay != null)
{
    <div class="my-4 px-4 py-3 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg text-sm flex flex-wrap items-center gap-x-3 gap-y-1">
        <span class="text-xs font-semibold uppercase tracking-wide text-gray-400 dark:text-gray-500 flex-shrink-0">On this day</span>
        <span class="text-gray-700 dark:text-gray-300">
            <a asp-controller="Roster" asp-action="Details" asp-route-slug="@Model.OnThisDay.AthleteSlug" class="font-medium hover:underline">@Model.OnThisDay.AthleteFullName</a>
            —
            <span class="mark font-semibold text-gray-900 dark:text-white">@Model.OnThisDay.Performance</span>
            in @Model.OnThisDay.EventName
            @if (Model.OnThisDay.IsSchoolRecord) { <span class="chip-sr">SR</span> }
        </span>
        <span class="text-gray-400 dark:text-gray-500">@Model.OnThisDay.Date.ToString("MMM d, yyyy")</span>
    </div>
}
