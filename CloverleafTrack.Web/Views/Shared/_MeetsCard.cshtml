@model SeasonMeetsViewModel

@{
    var upcomingMeets = Model.Meets.Where(m => m.IsUpcoming).OrderBy(m => m.Date).ToList();
    var completedMeets = Model.Meets.Where(m => !m.IsUpcoming).OrderByDescending(m => m.Date).ToList();
}

@if (Model.IsCurrentSeason)
{
    <!-- Current season: always expanded, upcoming separated above completed -->
    <div class="mb-12" data-filterable-section>
        <div class="flex items-center justify-between mb-6">
            <div>
                <h2 class="text-2xl font-bold text-gray-900 dark:text-white">@Model.SeasonName</h2>
                <p class="text-gray-500 dark:text-gray-400 text-sm mt-1">
                    Current season · @Model.CompletedMeets of @Model.TotalMeets meets completed
                </p>
            </div>
            <div class="flex gap-4 text-sm">
                <div class="text-center bg-white dark:bg-gray-800 border border-blue-200 dark:border-blue-700/30 rounded-lg p-2">
                    <div class="text-xl font-bold text-blue-700 dark:text-blue-300">@Model.TotalPRs</div>
                    <div class="text-xs text-gray-500 dark:text-gray-400">PRs</div>
                </div>
                <div class="text-center bg-white dark:bg-gray-800 border border-yellow-200 dark:border-yellow-700/30 rounded-lg p-2">
                    <div class="text-xl font-bold text-yellow-700 dark:text-yellow-300">@Model.TotalSchoolRecords</div>
                    <div class="text-xs text-gray-500 dark:text-gray-400">SRs</div>
                </div>
            </div>
        </div>

        @if (upcomingMeets.Any())
        {
            <div class="mb-6">
                <h3 class="text-sm font-semibold text-green-700 dark:text-green-400 uppercase tracking-wide mb-3 flex items-center gap-2">
                    <span class="inline-block w-1 h-4 bg-green-500 rounded"></span>
                    Coming Up
                </h3>
                <div class="space-y-2">
                    @foreach (var meet in upcomingMeets)
                    {
                        @await Html.PartialAsync("_MeetListItem", meet)
                    }
                </div>
            </div>
        }

        @if (completedMeets.Any())
        {
            @if (upcomingMeets.Any())
            {
                <h3 class="text-sm font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wide mb-3 flex items-center gap-2">
                    <span class="inline-block w-1 h-4 bg-gray-400 rounded"></span>
                    Completed
                </h3>
            }
            <div class="space-y-2">
                @foreach (var meet in completedMeets)
                {
                    @await Html.PartialAsync("_MeetListItem", meet)
                }
            </div>
        }
    </div>
}
else
{
    <!-- Past seasons: collapsed by default -->
    <details class="mb-4" data-filterable-section>
        <summary class="cursor-pointer list-none">
            <div class="flex items-center justify-between p-4 bg-white dark:bg-gray-800 rounded-lg border border-gray-200 dark:border-gray-700 hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors">
                <div class="flex items-center gap-3">
                    <svg class="w-4 h-4 text-gray-400 transition-transform details-arrow" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                    </svg>
                    <span class="font-semibold text-gray-900 dark:text-white">@Model.SeasonName</span>
                    <span class="text-sm text-gray-500 dark:text-gray-400">@Model.TotalMeets meets</span>
                </div>
                <div class="flex gap-3 text-sm">
                    @if (Model.TotalPRs > 0)
                    {
                        <span class="text-blue-600 dark:text-blue-400 font-medium">@Model.TotalPRs PRs</span>
                    }
                    @if (Model.TotalSchoolRecords > 0)
                    {
                        <span class="text-yellow-600 dark:text-yellow-400 font-medium">@Model.TotalSchoolRecords SRs</span>
                    }
                </div>
            </div>
        </summary>
        <div class="mt-2 space-y-2 ml-4">
            @foreach (var meet in completedMeets.Concat(upcomingMeets))
            {
                @await Html.PartialAsync("_MeetListItem", meet)
            }
        </div>
    </details>
}
