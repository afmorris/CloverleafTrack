@* ViewData keys: Label (string), FilterKey (string), Options (IEnumerable<(string Value, string Label)>) *@
@{
    var label = ViewData["Label"]?.ToString() ?? "";
    var filterKey = ViewData["FilterKey"]?.ToString() ?? "";
    var options = (IEnumerable<(string Value, string Label)>)ViewData["Options"]!;
}

<div class="filter-group flex flex-wrap items-center gap-1.5"
     data-filter-key="@filterKey"
     role="group"
     aria-label="@label filter">
    <span class="text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wide mr-1">@label</span>
    @foreach (var opt in options)
    {
        <button type="button"
                data-value="@opt.Value"
                aria-pressed="false"
                class="filter-chip-inactive px-3 py-1 rounded-full text-sm font-medium border transition-all focus:outline-none focus:ring-2 focus:ring-offset-1 focus:ring-blue-500">
            @opt.Label
        </button>
    }
</div>
