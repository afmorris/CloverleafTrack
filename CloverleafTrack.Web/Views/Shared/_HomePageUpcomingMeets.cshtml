@model HomePageViewModel

@if (Model.UpcomingMeets.Any())
{
    <section class="mb-6">
        <h2 class="text-sm font-semibold uppercase tracking-wide text-gray-500 dark:text-gray-400 mb-3">Upcoming meets</h2>

        <div class="bg-white dark:bg-gray-800 rounded-lg border border-gray-200 dark:border-gray-700 overflow-hidden">
            <div class="divide-y divide-gray-100 dark:divide-gray-800">
                @foreach (var meet in Model.UpcomingMeets)
                {
                    <a asp-controller="Meets" asp-action="Details" asp-route-slug="@meet.Slug"
                       class="flex items-center gap-4 px-4 py-3 hover:bg-gray-50 dark:hover:bg-gray-700/50 transition-colors">
                        <div class="flex-shrink-0 text-center min-w-[40px]">
                            <div class="text-xs font-semibold text-gray-400 dark:text-gray-500 uppercase">@meet.Date.ToString("MMM")</div>
                            <div class="text-lg font-bold text-gray-900 dark:text-white leading-tight">@meet.Date.Day</div>
                        </div>
                        <div class="flex-1 min-w-0">
                            <div class="font-medium text-gray-900 dark:text-white truncate">@meet.Name</div>
                            <div class="text-xs text-gray-500 dark:text-gray-400">
                                @meet.Environment.ToString()
                                @if (!string.IsNullOrEmpty(meet.Location)) { <span> · @meet.Location</span> }
                            </div>
                        </div>
                        <svg class="w-4 h-4 text-gray-300 dark:text-gray-600 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                        </svg>
                    </a>
                }
            </div>
        </div>
    </section>
}
