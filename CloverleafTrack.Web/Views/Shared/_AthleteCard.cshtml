@model AthleteViewModel

<a href="@Url.Action("Details", "Roster", new { slug = Model.AthleteSlug })"
   class="athlete-card bg-white dark:bg-gray-800 hover:bg-gray-50 dark:hover:bg-gray-700 border border-gray-200 dark:border-gray-700 rounded-xl p-5 block hover:shadow-lg transition-all"
   aria-label="View @Model.FullName's profile">
    <div class="flex items-start justify-between mb-3">
        <div>
            <h4 class="text-lg font-bold text-gray-900 dark:text-white mb-1">@Model.FullName</h4>
            <div class="text-sm text-gray-600 dark:text-gray-400">@Model.Class</div>
        </div>
        <div class="text-xl" aria-hidden="true">
            @if (Model.Gender == CloverleafTrack.Models.Enums.Gender.Male)
            {
                <span class="text-blue-400">♂</span>
            }
            else
            {
                <span class="text-pink-400">♀</span>
            }
        </div>
    </div>

    <div class="space-y-1.5">
        @foreach (var evt in Model.EventsInCategory.Take(4))
        {
            <div class="flex items-center justify-between text-sm">
                <span class="text-gray-700 dark:text-gray-300 flex items-center gap-1.5 truncate mr-2">
                    <span class="flex-shrink-0 text-xs" aria-label="@(evt.Environment == CloverleafTrack.Models.Enums.Environment.Indoor ? "Indoor" : "Outdoor")">
                        @(evt.Environment == CloverleafTrack.Models.Enums.Environment.Indoor ? "🏢" : "☀️")
                    </span>
                    <span class="truncate">@evt.Name</span>
                </span>
                <span class="font-mono font-semibold text-gray-900 dark:text-white flex-shrink-0">@evt.PersonalRecord</span>
            </div>
        }

        @if (Model.EventsInCategory.Count > 4)
        {
            <div class="text-xs text-gray-500 dark:text-gray-400 mt-1">
                + @(Model.EventsInCategory.Count - 4) more events
            </div>
        }
    </div>
</a>
