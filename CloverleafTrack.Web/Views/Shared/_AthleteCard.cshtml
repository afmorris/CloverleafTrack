@model AthleteViewModel

<a href="@Url.Action("Details", "Roster", new { slug = Model.AthleteSlug })"
   class="bg-white dark:bg-gray-800 hover:bg-gray-50 dark:hover:bg-gray-700/60 border border-gray-200 dark:border-gray-700 rounded-lg p-4 block transition-colors"
   aria-label="View @Model.FullName's profile">
    <div class="flex items-start justify-between mb-2">
        <div>
            <h4 class="font-semibold text-gray-900 dark:text-white">@Model.FullName</h4>
            <div class="text-xs text-gray-500 dark:text-gray-400 mt-0.5">@Model.Class</div>
        </div>
        <div class="text-sm font-medium" aria-hidden="true">
            @if (Model.Gender == CloverleafTrack.Models.Enums.Gender.Male)
            {
                <span class="text-blue-500 dark:text-blue-400">M</span>
            }
            else
            {
                <span class="text-pink-500 dark:text-pink-400">F</span>
            }
        </div>
    </div>

    <div class="space-y-1">
        @foreach (var evt in Model.EventsInCategory.Take(4))
        {
            <div class="flex items-center justify-between text-sm">
                <span class="text-gray-600 dark:text-gray-400 truncate mr-2 flex items-center gap-1">
                    <span class="text-xs text-gray-400 dark:text-gray-600 flex-shrink-0"
                          aria-label="@(evt.Environment == CloverleafTrack.Models.Enums.Environment.Indoor ? "Indoor" : "Outdoor")">
                        @(evt.Environment == CloverleafTrack.Models.Enums.Environment.Indoor ? "In" : "Out")
                    </span>
                    <span class="truncate">@evt.Name</span>
                </span>
                <span class="mark font-semibold text-gray-900 dark:text-white flex-shrink-0">@evt.PersonalRecord</span>
            </div>
        }

        @if (Model.EventsInCategory.Count > 4)
        {
            <div class="text-xs text-gray-400 dark:text-gray-500 mt-1">
                +@(Model.EventsInCategory.Count - 4) more
            </div>
        }
    </div>
</a>
